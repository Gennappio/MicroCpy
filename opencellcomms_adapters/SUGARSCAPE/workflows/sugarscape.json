{
  "version": "2.0",
  "name": "Sugarscape",
  "description": "Sugarscape on the ABM class layer, arranged for the current Space / Resources / Agents / Scheduler GUI.",
  "kernel": "biophysics",
  "metadata": {
    "author": "OpenCellComms",
    "created": "2026-06-13",
    "gui": {
      "function_libraries": [],
      "agent_kinds": [
        {
          "name": "forager",
          "init_subworkflow": "forager_init",
          "behavior_subworkflows": [
            "forager_step"
          ]
        }
      ],
      "resource_kinds": [
        {
          "name": "sugar",
          "init_subworkflow": "sugar_init",
          "behavior_subworkflows": [
            "sugar_growback"
          ]
        }
      ],
      "space": {
