      "description": "Main loop: ask foragers, then regrow sugar and report the population.",
      "enabled": true,
      "deletable": false,
      "controller": {
        "id": "controller-__scheduler__",
        "type": "initNode",
        "label": "SCHEDULER",
        "position": {
          "x": 100,
          "y": 100
        },
        "number_of_steps": 30
      },
      "functions": [],
      "subworkflow_calls": [
        {
          "id": "sched-call-forager-step",
          "type": "subworkflow_call",
          "subworkflow_name": "forager_step",
          "iterations": 1,
          "for_each": {
            "type": "agent",
            "kind": "forager",
            "order": "random"
          },
          "parameters": {},
          "enabled": true,
          "position": {
            "x": 400,
            "y": 140
          },
          "description": "Ask each forager to move, eat, and metabolize.",
          "parameter_nodes": []
        },
        {
          "id": "sched-call-sugar-growback",
          "type": "subworkflow_call",
          "subworkflow_name": "sugar_growback",
          "iterations": 1,
          "for_each": {
            "type": "resource",
            "kind": "sugar"
          },
          "parameters": {},
          "enabled": true,
          "position": {
            "x": 400,
            "y": 280
          },
          "description": "Regrow sugar, cull dead foragers, and print census.",
          "parameter_nodes": []
        }
      ],
      "parameters": [],
      "execution_order": [
        "sched-call-forager-step",
        "sched-call-sugar-growback"
      ],
      "input_parameters": []
    },
