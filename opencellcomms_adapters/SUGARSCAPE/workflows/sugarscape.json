        "tabs": [
          {
            "id": "tab-baseline",
            "name": "baseline_30_steps",
            "enabled": true,
            "parameterOverrides": {}
          },
          {
            "id": "tab-long",
            "name": "long_60_steps",
            "enabled": false,
            "parameterOverrides": {
              "__scheduler__": {
                "number_of_steps": 60
              }
            }
          }
        ]
      }
    }
  },
