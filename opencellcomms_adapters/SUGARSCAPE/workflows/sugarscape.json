          "y": 100
        },
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [
        {
          "id": "main-call-__init_sequence__",
          "type": "subworkflow_call",
          "subworkflow_name": "__init_sequence__",
          "iterations": 1,
          "parameters": {},
          "enabled": true,
          "position": {
            "x": 400,
            "y": 100
          },
          "description": "Initialization sequence",
          "parameter_nodes": []
        },
        {
          "id": "main-call-__scheduler__",
          "type": "subworkflow_call",
          "subworkflow_name": "__scheduler__",
          "iterations": 30,
          "parameters": {},
          "enabled": true,
          "position": {
            "x": 400,
            "y": 220
          },
          "description": "Main simulation loop",
          "parameter_nodes": []
        },
        {
          "id": "main-call-final_snapshot",
          "type": "subworkflow_call",
          "subworkflow_name": "final_snapshot",
          "iterations": 1,
          "parameters": {},
          "enabled": true,
          "position": {
            "x": 400,
            "y": 340
          },
          "description": "Processing: final snapshot",
          "parameter_nodes": []
