{
  "version": "2.0",
  "name": "PhysiCell Hill Rule Demo",
  "description": "Black-box facade demo: oxygen decays, an 'increases necrosis' Hill rule fires on every phenotype tick, and occ_events.jsonl streams rule_engine_changed events to the GUI. Builds against unmodified PhysiBoSS-master/. The whole PhysiCell setup + explicit Run node lives in one Processing behavior (kernel=biophysics, no hidden kernel dispatch).",
  "kernel": "biophysics",
  "metadata": {
    "author": "OpenCellComms / PhysiCell facade",
    "experiment": "PhysiCell black-box facade smoke",
    "notes": "Run via CLI: PHYSICELL_CPP=g++-14 PHYSIBOSS_ROOT=/path/to/PhysiBoSS-master python run_workflow.py --workflow opencellcomms_adapters/PhysiBoSS/workflows/physicell_hill_demo.json.",
    "gui": {
      "function_libraries": [],
      "agent_kinds": [],
      "scheduler": {
        "subworkflow": "__scheduler__"
      },
      "processing": {
        "behavior_subworkflows": [
          "physicell_setup"
        ]
      },
      "init_sequence": {
        "subworkflow": "__init_sequence__"
      },
      "main_is_synthesized": false,
      "user_functions": [],
      "world": {
        "subworkflow": null,
        "behavior_subworkflows": []
      }
    }
  },
  "subworkflows": {
    "main": {
      "description": "Orchestrator: init sequence -> scheduler -> PhysiCell run (processing).",
      "enabled": true,
      "deletable": false,
      "execution_order": [
        "main-call-__init_sequence__",
        "main-call-__scheduler__",
        "main-call-physicell_setup"
      ],
      "controller": {
        "id": "controller-main",
        "type": "controller",
        "label": "MAIN CONTROLLER",
        "position": {
          "x": 100.0,
          "y": 100.0
        },
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [
        {
          "id": "main-call-__init_sequence__",
          "type": "subworkflow_call",
          "subworkflow_name": "__init_sequence__",
          "iterations": 1,
          "enabled": true,
          "position": {
            "x": 400.0,
            "y": 100.0
          },
          "description": "Initialization sequence (empty \u2014 PhysiCell sets itself up)."
        },
        {
          "id": "main-call-__scheduler__",
          "type": "subworkflow_call",
          "subworkflow_name": "__scheduler__",
          "iterations": 1,
          "enabled": true,
          "position": {
            "x": 400.0,
            "y": 220.0
          },
          "description": "Main loop (empty \u2014 PhysiCell does its own internal stepping)."
        },
        {
          "id": "main-call-physicell_setup",
          "type": "subworkflow_call",
          "subworkflow_name": "physicell_setup",
          "iterations": 1,
          "enabled": true,
          "position": {
            "x": 400.0,
            "y": 340.0
          },
          "description": "Processing: PhysiCell setup + explicit Run + summary."
        }
      ],
      "parameters": []
    },
    "__init_sequence__": {
      "description": "Initialization order \u2014 empty for the PhysiCell facade.",
      "enabled": true,
      "deletable": false,
      "execution_order": [],
      "controller": {
        "id": "controller-__init_sequence__",
        "type": "controller",
        "label": "INIT SEQUENCE",
        "position": {
          "x": 100.0,
          "y": 100.0
        },
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [],
      "parameters": []
    },
    "__scheduler__": {
      "description": "Main simulation loop \u2014 empty. PhysiCell advances its own time internally inside the Run node.",
      "enabled": true,
      "deletable": false,
      "execution_order": [],
      "controller": {
        "id": "controller-__scheduler__",
        "type": "controller",
        "label": "SCHEDULER",
        "position": {
          "x": 100.0,
          "y": 100.0
        },
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [],
      "parameters": []
    },
    "physicell_setup": {
      "description": "Everything PhysiCell needs, on one Processing canvas: run config, 1 substrate (oxygen), 1 cell type, 1 Hill rule, the explicit Run node, and an event summary. The define/config nodes populate context['physicell_spec']; the Run node codegens, compiles, and runs the native binary.",
      "enabled": true,
      "deletable": true,
      "kind": "processing_behavior",
      "execution_order": [
        "cfg_physicell",
        "sub_o2",
        "ct_tumor",
        "rule_o2_necrosis",
        "run_sim",
        "summarize"
      ],
      "controller": {
        "id": "controller-physicell_setup",
        "type": "controller",
        "label": "PHYSICELL RUN",
        "position": {
          "x": 100.0,
          "y": -160.0
        },
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "cfg_physicell",
          "function_name": "set_physicell_config",
          "parameters": {},
          "enabled": true,
          "position": {
            "x": 100.0,
            "y": 100.0
          },
          "description": "Whole PhysiCell run configuration in one node: domain, timing, save cadence, options, parallelism, user parameters. Each group is an editable table driven by a dictParameterNode.",
          "step_count": 1,
          "parameter_nodes": [
            "pn_cfg_domain",
            "pn_cfg_overall",
            "pn_cfg_save",
            "pn_cfg_options",
            "pn_cfg_parallel",
            "pn_cfg_user_parameters"
          ]
        },
        {
          "id": "sub_o2",
          "function_name": "define_substrate",
          "parameters": {},
          "enabled": true,
          "position": {
            "x": 400.0,
            "y": 100.0
          },
          "description": "Oxygen substrate; high initial value + decay produces a falling signal over the run.",
          "step_count": 1,
          "parameter_nodes": [
            "pn_oxygen"
          ]
        },
        {
          "id": "ct_tumor",
          "function_name": "define_cell_type",
          "parameters": {},
          "enabled": true,
          "position": {
            "x": 700.0,
            "y": 100.0
          },
          "description": "Single tumor cell type; default phenotype values.",
          "step_count": 1,
          "parameter_nodes": [
            "pn_tumor"
          ]
        },
        {
          "id": "rule_o2_necrosis",
          "function_name": "define_hill_rule",
          "parameters": {},
          "enabled": true,
          "position": {
            "x": 1000.0,
            "y": 100.0
          },
          "description": "As oxygen increases, necrosis rate moves from 0 toward max_response=0.5.",
          "step_count": 1,
          "parameter_nodes": [
            "pn_rule_o2_necrosis"
          ]
        },
        {
          "id": "run_sim",
          "function_name": "run_physicell_simulation",
          "parameters": {},
          "enabled": true,
          "position": {
            "x": 1300.0,
            "y": 100.0
          },
          "description": "Explicit Run node: codegen -> make -> spawn -> tail occ_events.jsonl. Reads config + biology from context['physicell_spec']; needs no parameters of its own.",
          "step_count": 1,
          "parameter_nodes": []
        },
        {
          "id": "summarize",
