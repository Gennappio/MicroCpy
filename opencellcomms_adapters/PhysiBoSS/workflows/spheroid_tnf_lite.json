{
  "version": "2.0",
  "name": "Spheroid TNF (facade lite)",
  "description": "Phase-3-grammar approximation of upstream PhysiBoSS-master/sample_projects_intracellular/boolean/spheroid_tnf_model. Same microenvironment (oxygen + TNF) and same cell type, but the MaBoSS intracellular network and the custom TNF pulse injection from the upstream's main-spheroid_TNF.cpp are NOT expressible in the CBHG Hill-rule grammar; both are deferred to Phase 5 (fragment library). We approximate TNF-induced apoptosis with a Hill rule and add an oxygen→migration-speed rule for visualization. Treat this as a smoke test of the facade against a multi-substrate workflow, not a parity reproduction.",
  "kernel": "physicell",
  "kernel_config": {
    "physicell": {
      "domain": {
        "x_min": -500.0,
        "x_max": 500.0,
        "y_min": -500.0,
        "y_max": 500.0,
        "z_min": -10.0,
        "z_max": 10.0,
        "dx": 20.0,
        "dy": 20.0,
        "dz": 20.0,
        "use_2D": true
      },
      "overall": {
        "max_time": 60.0,
        "dt_diffusion": 0.02,
        "dt_mechanics": 0.1,
        "dt_phenotype": 2.0
      },
      "parallel": {
        "omp_num_threads": 4
      },
      "save": {
        "folder": "output",
        "full_data_interval": 15.0,
        "svg_interval": 15.0,
        "svg_enabled": false
      },
      "options": {
        "random_seed": 0,
        "virtual_wall_at_domain_edge": true
      },
      "user_parameters": {
        "number_of_cells": 12
      }
    }
  },
  "metadata": {
    "author": "OpenCellComms / PhysiCell facade",
    "experiment": "spheroid_tnf_model (lite) — Phase 3 facade smoke",
    "notes": "Run via CLI: PHYSICELL_CPP=g++-14 PHYSIBOSS_ROOT=/path/to/PhysiBoSS-master python run_workflow.py --workflow opencellcomms_gui/server/workflows/spheroid_tnf_lite.json. Phase 5 will add: MaBoSS BND/CFG support, per-cell-type phenotype overrides, and custom main-cpp fragments (TNF pulse).",
    "gui": {
      "function_libraries": [],
      "agent_kinds": [],
      "environment": {
        "init_subworkflow": null,
        "behavior_subworkflows": []
      },
      "init_sequence": {
        "subworkflow": "__init_sequence__"
      },
      "scheduler": {
        "subworkflow": "__scheduler__"
      },
      "processing": {
        "behavior_subworkflows": [
          "spheroid_tnf_setup"
        ]
      },
      "main_is_synthesized": false,
      "user_functions": []
    }
  },
  "subworkflows": {
    "__init_sequence__": {
      "description": "Initialization order — drag init subworkflows here",
      "deletable": false,
      "controller": {
        "id": "controller-__init_sequence__",
        "type": "initNode",
        "label": "INIT SEQUENCE",
        "position": {
          "x": 100.0,
          "y": 100.0
        },
        "number_of_steps": 1
      }
    },
    "__scheduler__": {
      "description": "Main simulation loop — order behaviors here",
      "deletable": false,
      "controller": {
        "id": "controller-__scheduler__",
        "type": "initNode",
        "label": "SCHEDULER",
        "position": {
          "x": 100.0,
          "y": 100.0
        },
        "number_of_steps": 100
      }
    },
    "spheroid_tnf_setup": {
      "description": "Codegen-only: 2 substrates, 1 cell type, 2 Hill rules. Execution is handed off to physicell_backend.run() — these nodes are no-ops at sim time.",
      "deletable": false,
      "execution_order": [
        "sub_oxygen",
        "sub_tnf",
        "ct_default",
        "rule_tnf_apoptosis",
        "rule_o2_migration",
        "run_sim"
      ],
      "controller": {
        "id": "controller-spheroid_tnf_setup",
        "type": "controller",
        "label": "PHYSICELL FACADE",
        "position": {
          "x": 600.0,
          "y": -120.0
        },
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "sub_oxygen",
          "function_name": "define_substrate",
          "position": {
            "x": 100.0,
            "y": 100.0
          },
          "description": "Oxygen substrate. Dirichlet boundary at 38 mmHg; cells uptake at rate 10 (default secretion in cell_def). Same as upstream.",
          "parameter_nodes": [
            "pn_oxygen"
          ]
        },
        {
          "id": "sub_tnf",
          "function_name": "define_substrate",
          "position": {
            "x": 380.0,
            "y": 100.0
          },
          "description": "TNF substrate. Upstream pulses TNF from main.cpp every tnf_pulse_period min — that's Phase 5. We approximate by seeding TNF uniformly at the pulse concentration and letting it decay (decay_rate=0.0275).",
          "parameter_nodes": [
            "pn_tnf"
          ]
        },
        {
          "id": "ct_default",
          "function_name": "define_cell_type",
          "position": {
            "x": 660.0,
            "y": 100.0
          },
          "description": "The 'default' tumor cell type. Upstream uses live-cell cycle (code 5) with rate 0.0011 + MaBoSS-driven death; the MVP template hardcodes Flow-cytometry cycle (code 6). Phase 3.5 will add per-cell-type cycle/death overrides.",
          "parameter_nodes": [
            "pn_default"
          ]
        },
        {
          "id": "rule_tnf_apoptosis",
          "function_name": "define_hill_rule",
          "position": {
            "x": 940.0,
            "y": 100.0
          },
          "description": "Hill approximation of the upstream MaBoSS TNF→FADD→Apoptosis path. As [TNF] rises, apoptosis rate climbs from cell_def base (5.3e-5) toward max_response.",
          "parameter_nodes": [
            "pn_rule_tnf_apoptosis"
          ]
        },
        {
          "id": "rule_o2_migration",
          "function_name": "define_hill_rule",
          "position": {
            "x": 1220.0,
            "y": 100.0
          },
          "description": "Visualization rule: cells migrate faster in oxygen-rich regions. Not in the upstream biology; included so the event stream shows >1 rate moving.",
          "parameter_nodes": [
            "pn_rule_o2_migration"
          ]
        },
        {
          "id": "run_sim",
          "function_name": "run_physicell_simulation",
          "position": {
            "x": 1540.0,
            "y": 100.0
          },
          "description": "Consumes the spec assembled by the define_* nodes above (context['physicell_spec']) and runs it: codegen -> make -> spawn -> tail. Writes the generated project, built binary, and event stream under the run's output dir, and stores them in context['physicell'].",
          "parameter_nodes": [
            "pn_domain",
            "pn_overall",
            "pn_save",
            "pn_user_parameters"
          ]
        }
      ],
      "parameters": [
        {
          "id": "pn_oxygen",
          "type": "dictParameterNode",
          "label": "Oxygen (substrate)",
          "target_param": "substrate",
          "position": {
            "x": 100.0,
            "y": 280.0
          },
