{
  "version": "2.0",
  "name": "Spheroid TNF (facade lite)",
  "description": "Phase-3-grammar approximation of upstream PhysiBoSS-master/sample_projects_intracellular/boolean/spheroid_tnf_model. Same microenvironment (oxygen + TNF) and same cell type, but the MaBoSS intracellular network and the custom TNF pulse injection from the upstream's main-spheroid_TNF.cpp are NOT expressible in the CBHG Hill-rule grammar; both are deferred to Phase 5. We approximate TNF-induced apoptosis with a Hill rule and add an oxygen->migration-speed rule for visualization. The whole PhysiCell setup + explicit Run node lives in one Processing behavior (kernel=biophysics, no hidden kernel dispatch).",
  "kernel": "biophysics",
  "metadata": {
    "author": "OpenCellComms / PhysiCell facade",
    "experiment": "spheroid_tnf_model (lite) — Phase 3 facade smoke",
    "notes": "Run via CLI: PHYSICELL_CPP=g++-14 PHYSIBOSS_ROOT=/path/to/PhysiBoSS-master python run_workflow.py --workflow opencellcomms_adapters/PhysiBoSS/workflows/spheroid_tnf_lite.json.",
    "gui": {
      "function_libraries": [],
      "agent_kinds": [],
      "environment": {
        "init_subworkflow": null,
        "behavior_subworkflows": []
      },
      "scheduler": {
        "subworkflow": "__scheduler__"
      },
      "processing": {
        "behavior_subworkflows": ["physicell_run"]
      },
      "init_sequence": {
        "subworkflow": "__init_sequence__"
      },
      "main_is_synthesized": false,
      "user_functions": []
    }
  },
  "subworkflows": {
    "main": {
      "description": "Orchestrator: init sequence -> scheduler -> PhysiCell run (processing).",
      "enabled": true,
      "deletable": false,
      "execution_order": ["main-call-__init_sequence__", "main-call-__scheduler__", "main-call-physicell_run"],
      "controller": {
        "id": "controller-main",
        "type": "controller",
        "label": "MAIN CONTROLLER",
        "position": {"x": 100.0, "y": 100.0},
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [
        {
          "id": "main-call-__init_sequence__",
          "type": "subworkflow_call",
          "subworkflow_name": "__init_sequence__",
          "iterations": 1,
          "enabled": true,
          "position": {"x": 400.0, "y": 100.0},
          "description": "Initialization sequence (empty — PhysiCell sets itself up)."
        },
        {
          "id": "main-call-__scheduler__",
          "type": "subworkflow_call",
          "subworkflow_name": "__scheduler__",
          "iterations": 1,
          "enabled": true,
          "position": {"x": 400.0, "y": 220.0},
          "description": "Main loop (empty — PhysiCell does its own internal stepping)."
        },
        {
          "id": "main-call-physicell_run",
          "type": "subworkflow_call",
          "subworkflow_name": "physicell_run",
          "iterations": 1,
          "enabled": true,
          "position": {"x": 400.0, "y": 340.0},
          "description": "Processing: PhysiCell setup + explicit Run + summary."
        }
      ],
      "parameters": []
    },
    "__init_sequence__": {
      "description": "Initialization order — empty for the PhysiCell facade.",
      "enabled": true,
      "deletable": false,
      "execution_order": [],
      "controller": {
        "id": "controller-__init_sequence__",
        "type": "controller",
        "label": "INIT SEQUENCE",
        "position": {"x": 100.0, "y": 100.0},
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [],
      "parameters": []
    },
    "__scheduler__": {
      "description": "Main simulation loop — empty. PhysiCell advances its own time internally inside the Run node.",
      "enabled": true,
      "deletable": false,
      "execution_order": [],
      "controller": {
        "id": "controller-__scheduler__",
        "type": "controller",
        "label": "SCHEDULER",
        "position": {"x": 100.0, "y": 100.0},
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [],
      "parameters": []
    },
    "physicell_run": {
      "description": "Everything PhysiCell needs, on one Processing canvas: run config, 2 substrates (oxygen, TNF), 1 cell type, 2 Hill rules, the explicit Run node, and an event summary. The define/config nodes populate context['physicell_spec']; the Run node codegens, compiles, and runs the native binary.",
      "enabled": true,
      "deletable": true,
      "kind": "processing_behavior",
      "execution_order": ["cfg_physicell", "sub_oxygen", "sub_tnf", "ct_default", "rule_tnf_apoptosis", "rule_o2_migration", "run_sim", "summarize"],
      "controller": {
        "id": "controller-physicell_run",
        "type": "controller",
        "label": "PHYSICELL RUN",
        "position": {"x": 100.0, "y": -160.0},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "cfg_physicell",
          "function_name": "set_physicell_config",
          "parameters": {},
          "enabled": true,
          "position": {"x": 100.0, "y": 100.0},
          "description": "Whole PhysiCell run configuration in one node: domain, timing, save cadence, options, parallelism, user parameters. Each group is an editable table driven by a dictParameterNode.",
          "step_count": 1,
          "parameter_nodes": ["pn_cfg_domain", "pn_cfg_overall", "pn_cfg_save", "pn_cfg_options", "pn_cfg_parallel", "pn_cfg_user_parameters"]
        },
        {
          "id": "sub_oxygen",
          "function_name": "define_substrate",
          "parameters": {},
          "enabled": true,
          "position": {"x": 400.0, "y": 100.0},
          "description": "Oxygen substrate. Dirichlet boundary at 38 mmHg.",
          "step_count": 1,
          "parameter_nodes": ["pn_oxygen"]
        },
        {
          "id": "sub_tnf",
          "function_name": "define_substrate",
          "parameters": {},
          "enabled": true,
          "position": {"x": 700.0, "y": 100.0},
          "description": "TNF substrate. Approximated as a uniform seed that decays (decay_rate=0.0275).",
          "step_count": 1,
          "parameter_nodes": ["pn_tnf"]
        },
        {
          "id": "ct_default",
          "function_name": "define_cell_type",
          "parameters": {},
          "enabled": true,
          "position": {"x": 1000.0, "y": 100.0},
          "description": "The 'default' tumor cell type.",
          "step_count": 1,
          "parameter_nodes": ["pn_default"]
        },
        {
          "id": "rule_tnf_apoptosis",
          "function_name": "define_hill_rule",
          "parameters": {},
          "enabled": true,
          "position": {"x": 1300.0, "y": 100.0},
          "description": "Hill approximation of TNF->FADD->Apoptosis: as [TNF] rises, apoptosis rate climbs toward max_response.",
          "step_count": 1,
          "parameter_nodes": ["pn_rule_tnf_apoptosis"]
        },
        {
          "id": "rule_o2_migration",
          "function_name": "define_hill_rule",
          "parameters": {},
          "enabled": true,
          "position": {"x": 1600.0, "y": 100.0},
          "description": "Visualization rule: cells migrate faster in oxygen-rich regions.",
          "step_count": 1,
          "parameter_nodes": ["pn_rule_o2_migration"]
        },
        {
          "id": "run_sim",
          "function_name": "run_physicell_simulation",
          "parameters": {},
          "enabled": true,
          "position": {"x": 1900.0, "y": 100.0},
          "description": "Explicit Run node: codegen -> make -> spawn -> tail occ_events.jsonl. Reads config + biology from context['physicell_spec']; needs no parameters of its own.",
          "step_count": 1,
          "parameter_nodes": []
        },
        {
          "id": "summarize",
          "function_name": "summarize_physicell_events",
          "parameters": {"max_lines_to_show": 5},
          "enabled": true,
          "position": {"x": 2200.0, "y": 100.0},
          "description": "Tally rule_engine_changed events.",
          "step_count": 1,
          "parameter_nodes": []
        }
      ],
      "subworkflow_calls": [],
      "parameters": [
        {
          "id": "pn_cfg_domain",
          "type": "dictParameterNode",
          "label": "domain",
          "target_param": "domain",
          "position": {"x": 100.0, "y": 280.0},
          "entries": [
            {"key": "x_min", "value": -500.0, "valueType": "float"},
            {"key": "x_max", "value": 500.0, "valueType": "float"},
            {"key": "y_min", "value": -500.0, "valueType": "float"},
            {"key": "y_max", "value": 500.0, "valueType": "float"},
            {"key": "z_min", "value": -10.0, "valueType": "float"},
            {"key": "z_max", "value": 10.0, "valueType": "float"},
            {"key": "dx", "value": 20.0, "valueType": "float"},
            {"key": "dy", "value": 20.0, "valueType": "float"},
            {"key": "dz", "value": 20.0, "valueType": "float"},
            {"key": "use_2D", "value": true, "valueType": "bool"}
          ]
        },
        {
          "id": "pn_cfg_overall",
          "type": "dictParameterNode",
          "label": "overall (timing)",
          "target_param": "overall",
          "position": {"x": 100.0, "y": 460.0},
          "entries": [
            {"key": "max_time", "value": 60.0, "valueType": "float"},
            {"key": "dt_diffusion", "value": 0.02, "valueType": "float"},
            {"key": "dt_mechanics", "value": 0.1, "valueType": "float"},
            {"key": "dt_phenotype", "value": 2.0, "valueType": "float"}
          ]
        },
        {
          "id": "pn_cfg_save",
          "type": "dictParameterNode",
          "label": "save",
          "target_param": "save",
