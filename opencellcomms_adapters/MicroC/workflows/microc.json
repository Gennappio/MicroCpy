    "tumor_cell_init": {
      "description": "MicroC: tumor_cell_init (seeds the tumor_cell agents into the world: load cells from checkpoint, then build per-cell gene networks)",
      "controller": {
        "id": "controller-tumor_cell_init",
        "type": "controller",
        "label": "TUMOR_CELL_INIT CONTROLLER",
        "position": {
          "x": 100,
          "y": 100
        },
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "agentinit-Setup_population-read_checkpoint",
          "function_name": "read_checkpoint",
          "position": {
            "x": 400,
            "y": 200
          },
          "description": "Read checkpoint file with cell positions and gene states. If gene states are present, initializes them.",
          "parameter_nodes": [
            "agentinit-Setup_population-param_checkpoint_file"
          ],
          "contract": {
            "reads": [
              "checkpoint",
              "agent.collection"
            ],
            "writes": [
              "agent.collection",
              "agent.self.gene_states"
            ],
            "emits": []
          }
        },
        {
          "id": "agentinit-Init_gene_networks-init_netlogo_gn",
          "function_name": "initialize_netlogo_gene_networks",
          "parameters": {
            "bnd_file": "../data/jaya.bnd",
            "random_initialization": true
          },
          "position": {
            "x": 400,
            "y": 300
          },
          "description": "Initialize NetLogo-faithful gene networks for all cells",
          "contract": {
            "reads": [
              "agent.collection",
              "gene_network.definition"
            ],
            "writes": [
              "gene_networks",
              "agent.self.gene_states"
            ],
            "emits": []
          }
        },
        {
          "id": "agentinit-Build_abm_population-build_abm",
          "function_name": "build_tumor_cell_abm_population",
          "position": {
            "x": 400,
            "y": 400
          },
          "description": "Wrap the loaded cells in an abm_population so MicroC runs on the ABM motor",
          "contract": {
            "reads": [
              "agent.collection",
              "simulation.config"
            ],
            "writes": [
              "abm_population"
            ],
            "emits": []
          }
        }
      ],
      "parameters": [
        {
          "id": "agentinit-Setup_population-param_checkpoint_file",
          "label": "Checkpoint File",
          "parameters": {
            "file_path": "../data/initial_cells_1000_center_1500.csv"
          },
          "position": {
            "x": 100,
            "y": 500
          }
        }
      ],
      "execution_order": [
        "agentinit-Setup_population-read_checkpoint",
        "agentinit-Init_gene_networks-init_netlogo_gn",
        "agentinit-Build_abm_population-build_abm"
      ],
      "contract": {
        "owner": {
          "type": "agent",
          "kind": "tumor_cell"
        },
        "reads": [
          "checkpoint",
          "simulation.config",
          "agent.collection"
        ],
        "writes": [
          "agent.collection",
          "agent.self.gene_states",
          "gene_networks"
        ],
        "emits": []
      }
    },
    "diffusion_step": {
      "description": "MicroC: diffusion_step",
      "controller": {
        "id": "controller-diffusion_step",
        "type": "controller",
        "label": "DIFFUSION_STEP CONTROLLER",
        "position": {
          "x": 100,
          "y": 100
