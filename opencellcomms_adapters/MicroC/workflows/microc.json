          "parameters": {
            "lactate_conversion_factor": 1,
            "glucose_conversion_factor": 1,
            "oxygen_conversion_factor": 1
          },
          "position": {
            "x": 400,
            "y": 100
          },
          "description": "COUPLED solver - iterative coupling with under-relaxation. Physically correct, prevents negative concentrations.",
          "custom_name": "run_diffusion_solver_coupled",
          "parameter_nodes": [
            "diffusion_step-param_max_iterations",
            "diffusion_step-param_tolerance",
            "diffusion_step-param_solver_type",
