{
  "format": "subworkflow",
  "name": "gene_update",
  "kind": "agent_behavior",
  "subworkflow": {
    "description": "MicroC: gene_update",
    "controller": {
      "id": "controller-gene_update",
      "type": "controller",
      "label": "GENE_UPDATE CONTROLLER",
      "position": {
        "x": 100,
        "y": 100
      },
      "number_of_steps": 1
    },
    "functions": [
      {
        "id": "gene_update-apply_associations",
        "function_name": "apply_associations_to_inputs",
        "position": {
          "x": 400,
          "y": 100
        },
        "description": "Translate substance concentrations → gene input states via associations"
      },
      {
        "id": "gene_update-propagate_genes_netlogo",
        "function_name": "propagate_gene_networks_netlogo",
        "parameters": {
          "propagation_steps": "5",
          "reversible": false,
          "verbose": false,
          "debug_steps": false,
          "oscillation": "true",
          "oscillation_period": "100",
          "ran_refresh": false,
          "diffusion_step": 0,
          "reset_fate": true
        },
        "position": {
          "x": 400,
          "y": 200
        },
        "description": "NetLogo-faithful graph walking gene network propagation",
        "custom_name": "propagate_gene_networks_netlogo"
      }
    ],
    "execution_order": [
      "gene_update-apply_associations",
      "gene_update-propagate_genes_netlogo"
    ]
  }
}
