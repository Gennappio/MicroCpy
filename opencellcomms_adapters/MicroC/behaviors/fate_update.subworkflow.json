{
  "format": "subworkflow",
  "version": "1.0",
  "name": "fate_update",
  "kind": "env_behavior",
  "description": "MicroC: fate_update",
  "exported_from": "MicroC",
  "subworkflow": {
    "description": "MicroC: fate_update",
    "controller": {
      "id": "controller-fate_update",
      "type": "controller",
      "label": "FATE_UPDATE CONTROLLER",
      "position": {
        "x": 100,
        "y": 100
      },
      "number_of_steps": 1
    },
    "functions": [
      {
        "id": "fate_update-mark_necrotic",
        "function_name": "mark_necrotic_cells",
        "position": {
          "x": 400,
          "y": 100
        },
        "description": "Mark cells as necrotic based on user-defined conditions",
        "parameter_nodes": [
          "fate_update-param_necrosis_params"
        ],
        "contract": {
          "phase": "coupling",
          "participants": [
            {
              "type": "agent",
              "kind": "tumor_cell"
            },
            {
              "type": "resource"
            }
          ],
          "reads": [
            "agent.collection",
            "resource.fields"
          ],
          "writes": [
            "agent.self.phenotype",
            "simulation.results"
          ],
          "emits": []
        }
      },
      {
        "id": "fate_update-mark_growth_arrest",
        "function_name": "mark_growth_arrest_cells",
        "position": {
          "x": 400,
          "y": 200
        },
        "description": "Track cells in Growth_Arrest state with time limit",
        "parameter_nodes": [
          "fate_update-param_max_growth_arrest_steps"
        ],
        "contract": {
          "phase": "agent_behavior",
          "owner": {
            "type": "agent",
            "kind": "tumor_cell"
          },
          "reads": [
            "agent.self.gene_states",
            "gene_networks"
          ],
          "writes": [
            "agent.self.phenotype",
            "simulation.results"
          ],
          "emits": []
        }
      },
      {
        "id": "fate_update-mark_apoptotic",
        "function_name": "mark_apoptotic_cells",
        "position": {
          "x": 400,
          "y": 300
        },
        "description": "Mark cells as apoptotic based on gene network Apoptosis output",
        "contract": {
          "phase": "agent_behavior",
          "owner": {
            "type": "agent",
            "kind": "tumor_cell"
          },
          "reads": [
            "agent.self.gene_states",
            "gene_networks"
          ],
          "writes": [
            "agent.self.phenotype",
            "simulation.results"
          ],
          "emits": []
        }
      },
      {
        "id": "fate_update-mark_proliferating",
        "function_name": "mark_proliferating_cells",
        "position": {
          "x": 400,
          "y": 400
        },
        "description": "Mark cells as Proliferation or Quiescence based on gene network",
        "contract": {
          "phase": "agent_behavior",
          "owner": {
            "type": "agent",
            "kind": "tumor_cell"
          },
          "reads": [
            "agent.self.gene_states",
            "gene_networks"
          ],
          "writes": [
            "agent.self.phenotype",
            "simulation.results"
          ],
          "emits": []
        }
      }
    ],
    "parameters": [
      {
        "id": "fate_update-param_necrosis_params",
        "type": "dictParameterNode",
        "label": "Necrosis Parameters",
        "target_param": "necrosis_params",
        "entries": [
          {
            "key": "oxygen_threshold",
            "valueType": "float",
            "value": 0.011
          },
          {
            "key": "glucose_threshold",
            "valueType": "float",
            "value": 0.39
          },
          {
            "key": "require_both",
            "valueType": "bool",
            "value": true
          }
        ],
        "position": {
          "x": 100,
          "y": 400
        }
      },
      {
        "id": "fate_update-param_max_growth_arrest_steps",
        "label": "Max Growth Arrest Steps",
        "parameters": {
          "max_growth_arrest_steps": 100
        },
        "position": {
          "x": 100,
          "y": 500
        }
      }
    ],
    "execution_order": [
      "fate_update-mark_necrotic",
      "fate_update-mark_growth_arrest",
      "fate_update-mark_apoptotic",
      "fate_update-mark_proliferating"
    ],
    "contract": {
      "phase": "coupling",
      "participants": [
        {
          "type": "agent",
          "kind": "tumor_cell"
        },
        {
          "type": "resource"
        }
      ],
      "reads": [
        "agent.collection",
        "agent.self.gene_states",
        "resource.fields",
        "gene_networks"
      ],
      "writes": [
        "agent.self.phenotype",
        "simulation.results"
      ],
      "emits": []
    }
  },
  "dependencies": {
    "subworkflows_referenced": [],
    "functions_required": [
      "mark_apoptotic_cells",
      "mark_growth_arrest_cells",
      "mark_necrotic_cells",
      "mark_proliferating_cells"
    ]
  }
}
