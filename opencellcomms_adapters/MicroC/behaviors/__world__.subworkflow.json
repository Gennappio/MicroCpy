{
  "format": "subworkflow",
  "version": "1.0",
  "name": "__world__",
  "kind": "world",
  "description": "MicroC: __world__ (sets up the world: simulation, domain, the empty population container bound to the domain grid, substances, associations)",
  "exported_from": "MicroC",
  "subworkflow": {
    "description": "MicroC: __world__ (sets up the world: simulation, domain, the empty population container bound to the domain grid, substances, associations)",
    "controller": {
      "id": "controller-__world__",
      "type": "controller",
      "label": "ENVIRONMENT_INIT CONTROLLER",
      "position": {
        "x": 100,
        "y": 100
      },
      "number_of_steps": 1
    },
    "functions": [
      {
        "id": "envinit-Setup_simulation-setup_sim",
        "function_name": "setup_simulation",
        "position": {
          "x": 400,
          "y": 100
        },
        "description": "Initialize simulation infrastructure",
        "parameter_nodes": [
          "envinit-Setup_simulation-param_sim_name",
          "envinit-Setup_simulation-param_sim_total_steps",
          "envinit-Setup_simulation-param_sim_dt",
          "envinit-Setup_simulation-param_sim_output_dir"
        ],
        "contract": {
          "reads": [
            "simulation.parameters"
          ],
          "writes": [
            "simulation.config",
            "simulation.results"
          ],
          "emits": []
        }
      },
      {
        "id": "envinit-Setup_simulation-setup_domain_node",
        "function_name": "setup_domain",
        "position": {
          "x": 400,
          "y": 200
        },
        "description": "Define 2D spatial domain",
        "parameter_nodes": [
          "envinit-Setup_simulation-param_domain_dimensions",
          "envinit-Setup_simulation-param_domain_size_x",
          "envinit-Setup_simulation-param_domain_size_y",
          "envinit-Setup_simulation-param_domain_nx",
          "envinit-Setup_simulation-param_domain_ny",
          "envinit-Setup_simulation-param_domain_cell_height",
          "envinit-Setup_simulation-param_1771966627094"
        ],
        "contract": {
          "reads": [
            "simulation.parameters"
          ],
          "writes": [
            "world.self",
            "simulation.config"
          ],
          "emits": []
        }
      },
      {
        "id": "envinit-Setup_population-setup_pop",
        "function_name": "setup_population",
        "parameters": {
          "enable_gene_network": true,
          "custom_functions_module": "../custom_functions/jayatilake_experiment_cell_functions.py"
        },
        "position": {
          "x": 400,
          "y": 250
        },
        "description": "Create the (empty) cell population container bound to the domain grid. Cells are placed later by the agent init (read_checkpoint).",
        "contract": {
          "reads": [
            "world.self",
            "simulation.config"
          ],
          "writes": [
            "agent.collection",
            "gene_networks"
          ],
          "emits": []
        }
      },
      {
        "id": "envinit-Setup_substances-setup_all_substances",
        "function_name": "setup_substances",
        "position": {
          "x": 400,
          "y": 300
        },
        "description": "Configure all 8 substances for diffusion-reaction",
        "parameter_nodes": [
          "envinit-Setup_substances-param_substances_list"
        ],
        "contract": {
          "reads": [
            "simulation.config"
          ],
          "writes": [
            "resource.collection",
            "resource.fields"
          ],
          "emits": []
        }
      },
      {
        "id": "envinit-Setup_associations-setup_all_associations",
        "function_name": "setup_associations",
        "position": {
          "x": 400,
          "y": 400
        },
        "description": "Configure all substance-to-gene associations",
        "parameter_nodes": [
          "envinit-Setup_associations-param_associations_dict"
        ],
        "contract": {
          "reads": [
            "simulation.parameters"
          ],
          "writes": [
            "associations",
            "simulation.config"
          ],
          "emits": []
        }
      }
    ],
    "parameters": [
