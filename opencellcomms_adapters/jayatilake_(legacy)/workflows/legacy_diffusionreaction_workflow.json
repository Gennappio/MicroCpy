{
  "version": "1.0",
  "name": "Diffusion-Reaction Workflow",
  "description": "Domain setup with substances (production/consumption per cell), population, and steady-state FiPy diffusion. Parameters from diffusion-parameters.txt.",
  "metadata": {
    "author": "OpenCellComms Team",
    "experiment": "Diffusion-Reaction Test",
    "created": "2026-01-06",
    "notes": "Reusable workflow for diffusion-reaction with cell metabolism. Single macrostep (steady state). Plot functions use context['plots_dir'] via Clean Architecture."
  },
  "stages": {
    "initialization": {
      "enabled": true,
      "description": "Setup domain, substances with production/consumption rates, and cell population.",
      "functions": [
        {
          "id": "setup_sim",
          "function_name": "setup_simulation",
          "enabled": true,
          "description": "Initialize simulation infrastructure",
          "parameters": {},
          "parameter_nodes": ["param_sim_name", "param_sim_total_steps", "param_sim_dt", "param_sim_output_dir"]
        },
        {
          "id": "setup_domain_node",
          "function_name": "setup_domain",
          "enabled": true,
          "description": "Define 2D spatial domain",
          "parameters": {},
          "parameter_nodes": ["param_domain_dimensions", "param_domain_size_x", "param_domain_size_y", "param_domain_nx", "param_domain_ny", "param_domain_cell_height"]
        },
        {
          "id": "add_oxygen",
          "function_name": "add_substance",
          "enabled": true,
          "description": "Oxygen: consumed by cells",
          "parameters": {},
          "parameter_nodes": ["param_oxygen_name", "param_oxygen_diffusion_coeff", "param_oxygen_production_rate", "param_oxygen_uptake_rate", "param_oxygen_initial_value", "param_oxygen_boundary_value", "param_oxygen_boundary_type", "param_oxygen_unit"]
        },
        {
          "id": "add_glucose",
          "function_name": "add_substance",
          "enabled": true,
          "description": "Glucose: consumed by cells",
          "parameters": {},
          "parameter_nodes": ["param_glucose_name", "param_glucose_diffusion_coeff", "param_glucose_production_rate", "param_glucose_uptake_rate", "param_glucose_initial_value", "param_glucose_boundary_value", "param_glucose_boundary_type", "param_glucose_unit"]
        },
        {
          "id": "add_lactate",
          "function_name": "add_substance",
          "enabled": true,
          "description": "Lactate: produced by cells",
          "parameters": {},
          "parameter_nodes": ["param_lactate_name", "param_lactate_diffusion_coeff", "param_lactate_production_rate", "param_lactate_uptake_rate", "param_lactate_initial_value", "param_lactate_boundary_value", "param_lactate_boundary_type", "param_lactate_unit"]
        },
        {
          "id": "add_h",
          "function_name": "add_substance",
          "enabled": true,
          "description": "H+ (protons): produced by cells",
          "parameters": {},
          "parameter_nodes": ["param_h_name", "param_h_diffusion_coeff", "param_h_production_rate", "param_h_uptake_rate", "param_h_initial_value", "param_h_boundary_value", "param_h_boundary_type", "param_h_unit"]
        },
        {
          "id": "add_tgfa",
          "function_name": "add_substance",
          "enabled": true,
          "description": "TGFA: growth factor",
          "parameters": {},
          "parameter_nodes": ["param_tgfa_name", "param_tgfa_diffusion_coeff", "param_tgfa_production_rate", "param_tgfa_uptake_rate", "param_tgfa_initial_value", "param_tgfa_boundary_value", "param_tgfa_boundary_type", "param_tgfa_unit"]
        },
        {
          "id": "add_fgf",
          "function_name": "add_substance",
          "enabled": true,
          "description": "FGF: growth factor",
          "parameters": {},
          "parameter_nodes": ["param_fgf_name", "param_fgf_diffusion_coeff", "param_fgf_production_rate", "param_fgf_uptake_rate", "param_fgf_initial_value", "param_fgf_boundary_value", "param_fgf_boundary_type", "param_fgf_unit"]
        },
        {
          "id": "add_hgf",
          "function_name": "add_substance",
          "enabled": true,
          "description": "HGF: growth factor",
          "parameters": {},
          "parameter_nodes": ["param_hgf_name", "param_hgf_diffusion_coeff", "param_hgf_production_rate", "param_hgf_uptake_rate", "param_hgf_initial_value", "param_hgf_boundary_value", "param_hgf_boundary_type", "param_hgf_unit"]
        },
        {
          "id": "add_gi",
          "function_name": "add_substance",
          "enabled": true,
          "description": "GI: growth inhibitor",
          "parameters": {},
          "parameter_nodes": ["param_gi_name", "param_gi_diffusion_coeff", "param_gi_production_rate", "param_gi_uptake_rate", "param_gi_initial_value", "param_gi_boundary_value", "param_gi_boundary_type", "param_gi_unit"]
        },
        {
          "id": "finalize_subs",
          "function_name": "finalize_substances",
          "enabled": true,
          "description": "Initialize simulator with all substances",
          "parameters": {}
        },
        {
          "id": "setup_pop",
          "function_name": "setup_population",
          "enabled": true,
          "description": "Initialize cell population (no gene network)",
          "parameters": {},
          "parameter_nodes": ["param_pop_enable_gene_network"]
        },
        {
          "id": "load_cells_csv",
          "function_name": "load_cells_from_csv",
          "enabled": true,
          "description": "Load cells from CSV",
          "parameters": {},
          "parameter_nodes": ["param_load_csv_file_path"]
        },
        {
          "id": "generate_initial_plots",
          "function_name": "generate_initial_plots",
          "enabled": true,
          "parameters": {}
        }
      ],
      "execution_order": [
        "setup_sim",
        "setup_domain_node",
        "add_oxygen",
        "add_glucose",
        "add_lactate",
        "add_h",
        "add_tgfa",
        "add_fgf",
        "add_hgf",
        "add_gi",
        "finalize_subs",
        "setup_pop",
        "load_cells_csv",
        "generate_initial_plots"
      ],
      "parameters": [
        {"id": "param_sim_name", "label": "Simulation Name", "parameters": {"name": "Diffusion-Reaction Test"}},
        {"id": "param_sim_total_steps", "label": "Total Steps", "parameters": {"total_steps": 1}},
        {"id": "param_sim_dt", "label": "Time Step (dt)", "parameters": {"dt": 1.0}},
        {"id": "param_sim_output_dir", "label": "Output Directory", "parameters": {"output_dir": "results"}},

        {"id": "param_domain_dimensions", "label": "Dimensions", "parameters": {"dimensions": 2}},
        {"id": "param_domain_size_x", "label": "Size X (μm)", "parameters": {"size_x": 500.0}},
        {"id": "param_domain_size_y", "label": "Size Y (μm)", "parameters": {"size_y": 500.0}},
        {"id": "param_domain_nx", "label": "Grid NX", "parameters": {"nx": 50}},
        {"id": "param_domain_ny", "label": "Grid NY", "parameters": {"ny": 50}},
        {"id": "param_domain_cell_height", "label": "Cell Height (μm)", "parameters": {"cell_height": 20.0}},

        {"id": "param_oxygen_name", "label": "Name", "parameters": {"substance_name": "Oxygen"}},
        {"id": "param_oxygen_diffusion_coeff", "label": "Diffusion Coefficient", "parameters": {"diffusion_coeff": 100000.0}},
        {"id": "param_oxygen_production_rate", "label": "Production Rate", "parameters": {"production_rate": 0.0}},
        {"id": "param_oxygen_uptake_rate", "label": "Uptake Rate", "parameters": {"uptake_rate": 0.0}},
        {"id": "param_oxygen_initial_value", "label": "Initial Value", "parameters": {"initial_value": 0.285}},
        {"id": "param_oxygen_boundary_value", "label": "Boundary Value", "parameters": {"boundary_value": 0.285}},
        {"id": "param_oxygen_boundary_type", "label": "Boundary Type", "parameters": {"boundary_type": "fixed"}},
        {"id": "param_oxygen_unit", "label": "Unit", "parameters": {"unit": "mM"}},

        {"id": "param_glucose_name", "label": "Name", "parameters": {"substance_name": "Glucose"}},
        {"id": "param_glucose_diffusion_coeff", "label": "Diffusion Coefficient", "parameters": {"diffusion_coeff": 18000.0}},
        {"id": "param_glucose_production_rate", "label": "Production Rate", "parameters": {"production_rate": 0.0}},
        {"id": "param_glucose_uptake_rate", "label": "Uptake Rate", "parameters": {"uptake_rate": 0.0}},
        {"id": "param_glucose_initial_value", "label": "Initial Value", "parameters": {"initial_value": 5.0}},
        {"id": "param_glucose_boundary_value", "label": "Boundary Value", "parameters": {"boundary_value": 5.0}},
        {"id": "param_glucose_boundary_type", "label": "Boundary Type", "parameters": {"boundary_type": "fixed"}},
        {"id": "param_glucose_unit", "label": "Unit", "parameters": {"unit": "mM"}},

        {"id": "param_lactate_name", "label": "Name", "parameters": {"substance_name": "Lactate"}},
        {"id": "param_lactate_diffusion_coeff", "label": "Diffusion Coefficient", "parameters": {"diffusion_coeff": 6000.0}},
        {"id": "param_lactate_production_rate", "label": "Production Rate", "parameters": {"production_rate": 0.0}},
        {"id": "param_lactate_uptake_rate", "label": "Uptake Rate", "parameters": {"uptake_rate": 0.0}},
        {"id": "param_lactate_initial_value", "label": "Initial Value", "parameters": {"initial_value": 0.0}},
        {"id": "param_lactate_boundary_value", "label": "Boundary Value", "parameters": {"boundary_value": 0.0}},
        {"id": "param_lactate_boundary_type", "label": "Boundary Type", "parameters": {"boundary_type": "fixed"}},
        {"id": "param_lactate_unit", "label": "Unit", "parameters": {"unit": "mM"}},

        {"id": "param_h_name", "label": "Name", "parameters": {"substance_name": "H"}},
        {"id": "param_h_diffusion_coeff", "label": "Diffusion Coefficient", "parameters": {"diffusion_coeff": 100000.0}},
        {"id": "param_h_production_rate", "label": "Production Rate", "parameters": {"production_rate": 0.1}},
        {"id": "param_h_uptake_rate", "label": "Uptake Rate", "parameters": {"uptake_rate": 0.0}},
        {"id": "param_h_initial_value", "label": "Initial Value", "parameters": {"initial_value": 0.0}},
        {"id": "param_h_boundary_value", "label": "Boundary Value", "parameters": {"boundary_value": 0.0}},
        {"id": "param_h_boundary_type", "label": "Boundary Type", "parameters": {"boundary_type": "fixed"}},
        {"id": "param_h_unit", "label": "Unit", "parameters": {"unit": "mM"}},

        {"id": "param_tgfa_name", "label": "Name", "parameters": {"substance_name": "TGFA"}},
        {"id": "param_tgfa_diffusion_coeff", "label": "Diffusion Coefficient", "parameters": {"diffusion_coeff": 1000.0}},
        {"id": "param_tgfa_production_rate", "label": "Production Rate", "parameters": {"production_rate": 0.01}},
        {"id": "param_tgfa_uptake_rate", "label": "Uptake Rate", "parameters": {"uptake_rate": 0.0}},
        {"id": "param_tgfa_initial_value", "label": "Initial Value", "parameters": {"initial_value": 0.0}},
        {"id": "param_tgfa_boundary_value", "label": "Boundary Value", "parameters": {"boundary_value": 0.0}},
        {"id": "param_tgfa_boundary_type", "label": "Boundary Type", "parameters": {"boundary_type": "neumann"}},
        {"id": "param_tgfa_unit", "label": "Unit", "parameters": {"unit": "nM"}},

        {"id": "param_fgf_name", "label": "Name", "parameters": {"substance_name": "FGF"}},
        {"id": "param_fgf_diffusion_coeff", "label": "Diffusion Coefficient", "parameters": {"diffusion_coeff": 1000.0}},
        {"id": "param_fgf_production_rate", "label": "Production Rate", "parameters": {"production_rate": 0.01}},
        {"id": "param_fgf_uptake_rate", "label": "Uptake Rate", "parameters": {"uptake_rate": 0.0}},
        {"id": "param_fgf_initial_value", "label": "Initial Value", "parameters": {"initial_value": 0.0}},
        {"id": "param_fgf_boundary_value", "label": "Boundary Value", "parameters": {"boundary_value": 0.0}},
        {"id": "param_fgf_boundary_type", "label": "Boundary Type", "parameters": {"boundary_type": "neumann"}},
        {"id": "param_fgf_unit", "label": "Unit", "parameters": {"unit": "nM"}},

        {"id": "param_hgf_name", "label": "Name", "parameters": {"substance_name": "HGF"}},
        {"id": "param_hgf_diffusion_coeff", "label": "Diffusion Coefficient", "parameters": {"diffusion_coeff": 1000.0}},
        {"id": "param_hgf_production_rate", "label": "Production Rate", "parameters": {"production_rate": 0.01}},
        {"id": "param_hgf_uptake_rate", "label": "Uptake Rate", "parameters": {"uptake_rate": 0.0}},
        {"id": "param_hgf_initial_value", "label": "Initial Value", "parameters": {"initial_value": 0.0}},
        {"id": "param_hgf_boundary_value", "label": "Boundary Value", "parameters": {"boundary_value": 0.0}},
        {"id": "param_hgf_boundary_type", "label": "Boundary Type", "parameters": {"boundary_type": "neumann"}},
        {"id": "param_hgf_unit", "label": "Unit", "parameters": {"unit": "nM"}},

        {"id": "param_gi_name", "label": "Name", "parameters": {"substance_name": "GI"}},
        {"id": "param_gi_diffusion_coeff", "label": "Diffusion Coefficient", "parameters": {"diffusion_coeff": 1000.0}},
        {"id": "param_gi_production_rate", "label": "Production Rate", "parameters": {"production_rate": 0.01}},
        {"id": "param_gi_uptake_rate", "label": "Uptake Rate", "parameters": {"uptake_rate": 0.0}},
        {"id": "param_gi_initial_value", "label": "Initial Value", "parameters": {"initial_value": 0.0}},
        {"id": "param_gi_boundary_value", "label": "Boundary Value", "parameters": {"boundary_value": 0.0}},
        {"id": "param_gi_boundary_type", "label": "Boundary Type", "parameters": {"boundary_type": "neumann"}},
        {"id": "param_gi_unit", "label": "Unit", "parameters": {"unit": "nM"}},

        {"id": "param_pop_enable_gene_network", "label": "Enable Gene Network", "parameters": {"enable_gene_network": false}},

        {"id": "param_load_csv_file_path", "label": "CSV File Path", "parameters": {"file_path": "tests/maboss_example/simple_cells.csv"}}
      ]
    },
    "macrostep": {
      "enabled": true,
      "description": "Single macrostep: run microenvironment (diffusion) once to reach steady state.",
      "steps": 1,
      "functions": [
        {
          "id": "run_microenv",
          "function_name": "microenvironment_step",
          "enabled": true,
          "description": "Run diffusion solver to steady state",
          "parameters": {"step_count": 1}
        }
      ],
      "execution_order": ["run_microenv"]
    },
    "microenvironment": {
      "enabled": true,
      "description": "Diffusion stage: solve steady-state diffusion with cell reactions.",
      "functions": [
        {
          "id": "diffusion_solver",
          "function_name": "run_diffusion_solver",
          "enabled": true,
          "description": "FiPy steady-state diffusion solver",
          "parameters": {},
          "parameter_nodes": ["param_diffusion_max_iter", "param_diffusion_tolerance", "param_diffusion_solver_type"]
        }
      ],
      "execution_order": ["diffusion_solver"],
      "parameters": [
        {"id": "param_diffusion_max_iter", "label": "Max Iterations", "parameters": {"max_iterations": 1000}},
        {"id": "param_diffusion_tolerance", "label": "Tolerance", "parameters": {"tolerance": 1e-6}},
        {"id": "param_diffusion_solver_type", "label": "Solver Type", "parameters": {"solver_type": "steady_state"}}
      ]
    },
    "finalization": {
      "enabled": true,
      "description": "Generate final plots and print summary statistics.",
      "functions": [
        {
          "id": "generate_plots",
          "function_name": "generate_summary_plots",
          "enabled": true,
          "parameters": {}
        },
        {
          "id": "print_summary",
          "function_name": "print_simulation_summary",
          "enabled": true,
          "parameters": {}
        }
      ],
      "execution_order": [
        "generate_plots",
        "print_summary"
      ]
    }
  }
}

