void create_cell_types( void )
{
    if ( parameters.ints.find_index("random_seed") != -1 )
    {
        SeedRandom( parameters.ints("random_seed") );
    }

    initialize_default_cell_definition();
    cell_defaults.phenotype.secretion.sync_to_microenvironment( &microenvironment );

    cell_defaults.functions.volume_update_function = standard_volume_update_function;
    cell_defaults.functions.update_velocity        = standard_update_cell_velocity;

    cell_defaults.functions.update_migration_bias  = NULL;
    cell_defaults.functions.update_phenotype       = NULL;
    cell_defaults.functions.custom_cell_rule       = NULL;
    cell_defaults.functions.contact_function       = NULL;

    cell_defaults.functions.add_cell_basement_membrane_interactions = NULL;
    cell_defaults.functions.calculate_distance_to_membrane          = NULL;

    initialize_cell_definitions_from_pugixml();
    build_cell_definitions_maps();
    setup_signal_behavior_dictionaries();
    setup_cell_rules();

    // Disable upstream's automatic per-tick apply_ruleset in
    // Cell::advance_bundled_phenotype_functions. The rules are still
    // loaded into hypothesis_rulesets; update_phenotype_composed below
    // owns the per-tick application so begin/end observability sees the
    // rate transition.
    PhysiCell_settings.rules_enabled = false;

    // The observability-wrapped phenotype is installed on every cell type.
    cell_defaults.functions.update_phenotype = update_phenotype_composed;
    cell_defaults.functions.custom_cell_rule = custom_function;
    cell_defaults.functions.contact_function = contact_function;

    display_cell_definitions( std::cout );
}

