{
  "version": "2.0",
  "name": "Brute Force Gene Network Benchmark",
  "description": "Run gene network update function multiple times and collect results. No legacy code.",
  "metadata": {
    "author": "OpenCellComms Team",
    "experiment": "Gene Network Benchmark",
    "created": "2026-01-21",
    "notes": "Composers contain ONLY subworkflow calls, no functions. Input nodes stay FIXED during propagation. Uses Clean Architecture with context['resolve_path'] for file resolution.",
    "gui": {
      "subworkflow_kinds": {
        "main": "composer",
        "initialization": "subworkflow",
        "loop": "subworkflow",
        "analysis": "subworkflow"
      }
    }
  },
  "subworkflows": {
    "main": {
      "description": "Main composer - orchestrates initialization, loop, and analysis workflows",
      "deletable": false,
      "controller": {
        "id": "controller-main",
        "label": "MAIN COMPOSER",
        "position": {"x": 50, "y": 50},
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [
        {
          "id": "call_initialization",
          "subworkflow_name": "initialization",
          "iterations": 1,
          "enabled": true,
          "description": "Initialize population and gene networks",
          "parameters": {},
          "context_mapping": {},
          "position": {"x": 200, "y": 100}
        },
        {
          "id": "call_loop",
          "subworkflow_name": "loop",
          "iterations": 10,
          "enabled": true,
          "description": "Run gene network updates multiple times",
          "parameters": {},
          "context_mapping": {},
          "position": {"x": 200, "y": 200}
        },
        {
          "id": "call_analysis",
          "subworkflow_name": "analysis",
          "iterations": 1,
          "enabled": true,
          "description": "Analyze and print results",
          "parameters": {},
          "context_mapping": {},
          "position": {"x": 200, "y": 300}
        }
      ],
      "parameters": [],
      "execution_order": ["call_initialization", "call_loop", "call_analysis"],
      "enabled": true
    },
    "initialization": {
      "description": "Initialize population, attach gene networks, set input states",
      "deletable": true,
      "controller": {
        "id": "controller-initialization",
        "label": "INITIALIZATION",
        "position": {"x": 50, "y": 50},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "init_population",
          "function_name": "initialize_population",
          "enabled": true,
          "description": "Create N cells (number of cells = number of parallel runs)",
          "parameters": {
            "num_cells": 100
          },
          "position": {"x": 200, "y": 100}
        },
        {
          "id": "init_gene_networks",
          "function_name": "initialize_gene_networks",
          "enabled": true,
          "description": "Attach gene networks to all cells (path resolved via context['resolve_path'])",
          "parameters": {
            "bnd_file": "tests/jayatilake_experiment/jaya.bnd",
            "random_initialization": true
          },
          "position": {"x": 200, "y": 200}
        },
        {
          "id": "set_inputs",
          "function_name": "set_gene_network_inputs",
          "enabled": true,
          "description": "Set input node states (stay FIXED during propagation)",
          "parameters": {
            "Oxygen_supply": true,
            "Glucose_supply": true,
            "MCT1_stimulus": false,
            "Proton_level": false,
            "FGFR_stimulus": false,
            "EGFR_stimulus": false,
            "cMET_stimulus": false,
            "Growth_Inhibitor": false,
            "DNA_damage": false,
            "TGFBR_stimulus": false
          },
          "position": {"x": 200, "y": 300}
        }
      ],
      "subworkflow_calls": [],
      "parameters": [],
      "execution_order": ["init_population", "init_gene_networks", "set_inputs"],
      "enabled": true
    },
    "loop": {
      "description": "Single gene network propagation step (called multiple times via iterations)",
      "deletable": true,
      "controller": {
        "id": "controller-loop",
        "label": "LOOP",
        "position": {"x": 50, "y": 50},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "update_gene_networks",
          "function_name": "update_gene_networks_standalone",
          "enabled": false,
          "description": "Propagate gene network for N steps (input nodes stay FIXED)",
          "parameters": {
            "propagation_steps": 500
          },
          "position": {"x": 200, "y": 100}
        },
        {
          "id": "update_gene_networks_hierarchical",
          "function_name": "update_gene_networks_hierarchical",
          "enabled": false,
          "description": "Propagate gene network with hierarchical fate logic (Proliferation > Growth_Arrest > Apoptosis > Necrosis)",
          "parameters": {
            "propagation_steps": 500,
            "verbose": false
          },
          "position": {"x": 200, "y": 200}
        },
        {
          "id": "update_gene_networks_netlogo",
          "function_name": "propagate_gene_networks_netlogo",
          "enabled": true,
          "description": "Jayatilake graph walking propagation",
          "parameters": {
            "propagation_steps": 100,
            "verbose": false
          },
          "position": {"x": 250, "y": 250}
        }
      ],
      "subworkflow_calls": [],
      "parameters": [],
      "execution_order": ["update_gene_networks", "update_gene_networks_hierarchical", "update_gene_networks_netlogo"],
      "enabled": true
    },
    "analysis": {
      "description": "Analyze and print gene network results",
      "deletable": true,
      "controller": {
        "id": "controller-analysis",
        "label": "ANALYSIS",
        "position": {"x": 50, "y": 50},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "print_results",
          "function_name": "print_gene_network_states",
          "enabled": true,
          "description": "Print gene network statistics",
          "parameters": {
            "show_per_cell": false
          },
          "position": {"x": 200, "y": 100}
        }
      ],
      "subworkflow_calls": [],
      "parameters": [],
      "execution_order": ["print_results"],
      "enabled": true
    }
  }
}
