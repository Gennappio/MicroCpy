{
  "version": "1.0",
  "name": "Gene Network Update Test",
  "description": "Granular workflow for gene network testing. Same structure as brute_gene_network_workflow.json.",
  "metadata": {
    "author": "MicroCpy Team",
    "experiment": "Gene Network Testing",
    "created": "2026-01-05",
    "notes": "Number of cells = number of runs. Input states set manually via canvas."
  },
  "stages": {
    "initialization": {
      "enabled": true,
      "description": "Initialize gene network, set inputs, create population",
      "functions": [
        {
          "id": "init_gene_network",
          "function_name": "initialize_standalone_gene_network",
          "enabled": true,
          "description": "Load BND file and create gene network",
          "parameters": {},
          "parameter_nodes": ["param_bnd_file", "param_random_init"]
        },
        {
          "id": "set_inputs",
          "function_name": "set_gene_network_inputs",
          "enabled": true,
          "description": "Set input node states",
          "parameters": {},
          "parameter_nodes": ["param_oxygen_supply", "param_glucose_supply"]
        },
        {
          "id": "create_population",
          "function_name": "create_test_population",
          "enabled": true,
          "description": "Create N cells",
          "parameters": {},
          "parameter_nodes": ["param_num_cells"]
        }
      ],
      "execution_order": ["init_gene_network", "set_inputs", "create_population"],
      "parameters": [
        {"id": "param_bnd_file", "label": "BND File Path", "parameters": {"bnd_file": "jaya_microc.bnd"}},
        {"id": "param_random_init", "label": "Random Initialization", "parameters": {"random_initialization": true}},
        {"id": "param_num_cells", "label": "Number of Cells (= runs)", "parameters": {"num_cells": 100}},
        {"id": "param_oxygen_supply", "label": "Oxygen Supply", "parameters": {"Oxygen_supply": true}},
        {"id": "param_glucose_supply", "label": "Glucose Supply", "parameters": {"Glucose_supply": true}}
      ]
    },
    "intracellular": {
      "enabled": true,
      "description": "Update gene networks",
      "functions": [
        {
          "id": "update_gene_networks_node",
          "function_name": "update_gene_networks",
          "enabled": true,
          "description": "Propagate gene network",
          "parameters": {},
          "parameter_nodes": ["param_propagation_steps"]
        }
      ],
      "execution_order": ["update_gene_networks_node"],
      "parameters": [
        {"id": "param_propagation_steps", "label": "Propagation Steps", "parameters": {"propagation_steps": 500}}
      ]
    },
    "macrostep": {
      "enabled": true,
      "description": "Run intracellular step",
      "steps": 1,
      "functions": [
        {
          "id": "intracellular_step_node",
          "function_name": "intracellular_step",
          "enabled": true,
          "description": "Execute intracellular stage",
          "parameters": {},
          "step_count": 1,
          "parameter_nodes": []
        }
      ],
      "execution_order": ["intracellular_step_node"],
      "parameters": []
    },
    "finalization": {
      "enabled": true,
      "description": "Print results",
      "functions": [
        {
          "id": "print_results",
          "function_name": "print_gene_network_states",
          "enabled": true,
          "description": "Print gene network statistics",
          "parameters": {},
          "parameter_nodes": ["param_show_per_cell"]
        }
      ],
      "execution_order": ["print_results"],
      "parameters": [
        {"id": "param_show_per_cell", "label": "Show Per-Cell Results", "parameters": {"show_per_cell": false}}
      ]
    }
  },
  "parameters": []
}
