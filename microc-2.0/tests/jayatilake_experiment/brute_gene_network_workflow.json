{
  "version": "1.0",
  "name": "Brute Force Gene Network Benchmark",
  "description": "REUSABLE workflow for gene network testing. Uses: Initialize Population -> Initialize Gene Networks -> Set Input States -> Update Gene Networks.",
  "metadata": {
    "author": "MicroCpy Team",
    "experiment": "Gene Network Benchmark",
    "created": "2026-01-05",
    "notes": "Number of cells = number of runs. Input nodes stay FIXED during propagation (they are excluded from updates)."
  },
  "stages": {
    "initialization": {
      "enabled": true,
      "description": "Initialize population, attach gene networks, set input states",
      "functions": [
        {
          "id": "init_population",
          "function_name": "initialize_population",
          "enabled": true,
          "description": "Create N cells (without gene networks yet)",
          "parameters": {},
          "parameter_nodes": ["param_num_cells"]
        },
        {
          "id": "init_gene_networks",
          "function_name": "initialize_gene_networks",
          "enabled": true,
          "description": "Attach gene networks to all cells",
          "parameters": {},
          "parameter_nodes": ["param_bnd_file", "param_random_init"]
        },
        {
          "id": "set_inputs",
          "function_name": "set_gene_network_inputs",
          "enabled": true,
          "description": "Set input node states (stay FIXED during propagation)",
          "parameters": {},
          "parameter_nodes": ["param_oxygen_supply", "param_glucose_supply", "param_mct1", "param_proton", "param_fgfr", "param_egfr", "param_cmet", "param_growth_inhibitor", "param_dna_damage", "param_tgfbr"]
        }
      ],
      "execution_order": ["init_population", "init_gene_networks", "set_inputs"],
      "parameters": [
        {"id": "param_bnd_file", "label": "BND File Path", "parameters": {"bnd_file": "jaya_microc.bnd"}},
        {"id": "param_random_init", "label": "Random Initialization", "parameters": {"random_initialization": true}},
        {"id": "param_num_cells", "label": "Number of Cells (= runs)", "parameters": {"num_cells": 100}},
        {"id": "param_oxygen_supply", "label": "Oxygen Supply", "parameters": {"Oxygen_supply": true}},
        {"id": "param_glucose_supply", "label": "Glucose Supply", "parameters": {"Glucose_supply": true}},
        {"id": "param_mct1", "label": "MCT1 Stimulus", "parameters": {"MCT1_stimulus": false}},
        {"id": "param_proton", "label": "Proton Level", "parameters": {"Proton_level": false}},
        {"id": "param_fgfr", "label": "FGFR Stimulus", "parameters": {"FGFR_stimulus": false}},
        {"id": "param_egfr", "label": "EGFR Stimulus", "parameters": {"EGFR_stimulus": false}},
        {"id": "param_cmet", "label": "cMET Stimulus", "parameters": {"cMET_stimulus": false}},
        {"id": "param_growth_inhibitor", "label": "Growth Inhibitor", "parameters": {"Growth_Inhibitor": false}},
        {"id": "param_dna_damage", "label": "DNA Damage", "parameters": {"DNA_damage": false}},
        {"id": "param_tgfbr", "label": "TGFBR Stimulus", "parameters": {"TGFBR_stimulus": false}}
      ]
    },
    "intracellular": {
      "enabled": true,
      "description": "Update gene networks (propagate signals) - input nodes stay FIXED",
      "functions": [
        {
          "id": "update_gene_networks_node",
          "function_name": "update_gene_networks_standalone",
          "enabled": true,
          "description": "Propagate gene network for N steps (input nodes stay FIXED)",
          "parameters": {},
          "parameter_nodes": ["param_propagation_steps"]
        }
      ],
      "execution_order": ["update_gene_networks_node"],
      "parameters": [
        {"id": "param_propagation_steps", "label": "Propagation Steps", "parameters": {"propagation_steps": 500}}
      ]
    },
    "macrostep": {
      "enabled": true,
      "description": "Run intracellular step",
      "steps": 1,
      "functions": [
        {
          "id": "intracellular_step_node",
          "function_name": "intracellular_step",
          "enabled": true,
          "description": "Execute intracellular stage",
          "parameters": {},
          "step_count": 1,
          "parameter_nodes": []
        }
      ],
      "execution_order": ["intracellular_step_node"],
      "parameters": []
    },
    "finalization": {
      "enabled": true,
      "description": "Print results",
      "functions": [
        {
          "id": "print_results",
          "function_name": "print_gene_network_states",
          "enabled": true,
          "description": "Print gene network statistics",
          "parameters": {},
          "parameter_nodes": ["param_show_per_cell"]
        }
      ],
      "execution_order": ["print_results"],
      "parameters": [
        {"id": "param_show_per_cell", "label": "Show Per-Cell Results", "parameters": {"show_per_cell": false}}
      ]
    }
  },
  "parameters": []
}
