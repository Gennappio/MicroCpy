          "parameters": {},
          "parameter_nodes": ["param_pop_enable_gene_network"],
          "position": {"x": 200, "y": 50}
        },
        {
          "id": "load_cells_csv",
          "function_name": "load_cells_from_csv",
          "enabled": true,
          "description": "Load cells from CSV file",
          "parameters": {},
          "parameter_nodes": ["param_load_csv_file_path"],
          "position": {"x": 200, "y": 150}
        }
      ],
      "subworkflow_calls": [],
      "parameters": [
        {"id": "param_pop_enable_gene_network", "label": "Enable Gene Network", "parameters": {"enable_gene_network": false}, "position": {"x": 400, "y": 50}},
