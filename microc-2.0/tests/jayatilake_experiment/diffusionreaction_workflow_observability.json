          "description": "Configure all 8 substances and initialize diffusion solver",
          "parameters": {},
          "parameter_nodes": ["param_substances_list"],
          "position": {"x": 400, "y": 100}
        }
      ],
      "subworkflow_calls": [],
      "parameters": [
        {
          "id": "param_substances_list",
          "type": "listParameterNode",
          "label": "Substances (JSON)",
          "listType": "string",
          "items": [
            "{\"name\":\"Oxygen\",\"diffusion_coeff\":100000.0,\"production_rate\":0.0,\"uptake_rate\":0.0,\"initial_value\":0.285,\"boundary_value\":0.285,\"boundary_type\":\"fixed\",\"unit\":\"mM\"}",
            "{\"name\":\"Glucose\",\"diffusion_coeff\":18000.0,\"production_rate\":0.0,\"uptake_rate\":0.0,\"initial_value\":5.0,\"boundary_value\":5.0,\"boundary_type\":\"fixed\",\"unit\":\"mM\"}",
            "{\"name\":\"Lactate\",\"diffusion_coeff\":6000.0,\"production_rate\":0.0,\"uptake_rate\":0.0,\"initial_value\":0.0,\"boundary_value\":0.0,\"boundary_type\":\"fixed\",\"unit\":\"mM\"}",
            "{\"name\":\"H\",\"diffusion_coeff\":100000.0,\"production_rate\":0.1,\"uptake_rate\":0.0,\"initial_value\":0.0,\"boundary_value\":0.0,\"boundary_type\":\"fixed\",\"unit\":\"mM\"}",
            "{\"name\":\"TGFA\",\"diffusion_coeff\":1000.0,\"production_rate\":0.01,\"uptake_rate\":0.0,\"initial_value\":0.0,\"boundary_value\":0.0,\"boundary_type\":\"neumann\",\"unit\":\"nM\"}",
            "{\"name\":\"FGF\",\"diffusion_coeff\":1000.0,\"production_rate\":0.01,\"uptake_rate\":0.0,\"initial_value\":0.0,\"boundary_value\":0.0,\"boundary_type\":\"neumann\",\"unit\":\"nM\"}",
            "{\"name\":\"HGF\",\"diffusion_coeff\":1000.0,\"production_rate\":0.01,\"uptake_rate\":0.0,\"initial_value\":0.0,\"boundary_value\":0.0,\"boundary_type\":\"neumann\",\"unit\":\"nM\"}",
            "{\"name\":\"GI\",\"diffusion_coeff\":1000.0,\"production_rate\":0.01,\"uptake_rate\":0.0,\"initial_value\":0.0,\"boundary_value\":0.0,\"boundary_type\":\"neumann\",\"unit\":\"nM\"}"
          ],
          "targetParam": "substances",
          "position": {"x": 100, "y": 100}
        }
      ],
      "execution_order": ["setup_all_substances"],
      "enabled": true
    },
