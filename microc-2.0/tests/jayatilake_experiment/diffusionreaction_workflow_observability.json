{
  "version": "2.0",
  "name": "Diffusion-Reaction Workflow (Observability)",
  "description": "Domain setup with substances (production/consumption per cell), population, and steady-state FiPy diffusion. Version 2.0 with observability enabled.",
  "metadata": {
    "author": "MicroCpy Team",
    "experiment": "Diffusion-Reaction Test",
    "created": "2026-01-19",
    "notes": "Reusable workflow for diffusion-reaction with cell metabolism. Single macrostep (steady state). v2.0 format with full observability support.",
    "gui": {
      "subworkflow_kinds": {
        "main": "composer",
        "initialization": "composer",
        "Setup_simulation": "subworkflow",
        "Setup_substances": "subworkflow",
        "Setup_population": "subworkflow",
        "Generate_plots": "subworkflow",
        "microenvironment": "subworkflow",
        "finalization": "composer",
        "Summarize_simulation": "subworkflow"
      }
    }
  },
  "subworkflows": {
    "main": {
      "description": "Main composer orchestrating initialization, macrostep, and finalization",
      "deletable": false,
      "controller": {
        "id": "controller-main",
        "label": "MAIN CONTROLLER",
        "position": {"x": 50, "y": 50},
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [
        {
          "id": "call_initialization",
          "subworkflow_name": "initialization",
          "iterations": 1,
          "enabled": true,
          "description": "Setup domain, substances, and cell population",
          "parameters": {},
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 100}
        },
        {
          "id": "call_microenvironment",
          "subworkflow_name": "microenvironment",
          "iterations": 1,
          "enabled": true,
          "description": "Run diffusion solver to steady state",
          "parameters": {},
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 250}
        },
        {
          "id": "call_finalization",
          "subworkflow_name": "finalization",
          "iterations": 1,
          "enabled": true,
          "description": "Generate plots and print summary",
          "parameters": {},
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 400}
        }
      ],
      "parameters": [],
      "execution_order": ["call_initialization", "call_microenvironment", "call_finalization"],
      "enabled": true
    },
    "initialization": {
      "description": "Initialization composer: orchestrates simulation setup, substances, population, and initial plots",
      "deletable": true,
      "controller": {
        "id": "controller-initialization",
        "label": "INITIALIZATION COMPOSER",
        "position": {"x": 50, "y": 50},
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [
        {
          "id": "call_setup_simulation",
          "subworkflow_name": "Setup_simulation",
          "iterations": 1,
          "enabled": true,
          "description": "Setup simulation and domain",
          "parameters": {},
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 100}
        },
        {
          "id": "call_setup_substances",
          "subworkflow_name": "Setup_substances",
          "iterations": 1,
          "enabled": true,
          "description": "Add all substances and finalize",
          "parameters": {},
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 250}
        },
        {
          "id": "call_setup_population",
          "subworkflow_name": "Setup_population",
          "iterations": 1,
          "enabled": true,
          "description": "Setup population and load cells",
          "parameters": {},
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 400}
        },
        {
          "id": "call_generate_plots_init",
          "subworkflow_name": "Generate_plots",
          "iterations": 1,
          "enabled": true,
          "description": "Generate initial state plots",
          "parameters": {},
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 550}
        }
      ],
      "parameters": [],
      "execution_order": ["call_setup_simulation", "call_setup_substances", "call_setup_population", "call_generate_plots_init"],
      "enabled": true
    },
    "microenvironment": {
      "description": "Diffusion stage: solve steady-state diffusion with cell reactions.",
      "deletable": true,
      "controller": {
        "id": "controller-microenvironment",
        "label": "MICROENVIRONMENT CONTROLLER",
        "position": {"x": 50, "y": 50},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "diffusion_solver",
          "function_name": "run_diffusion_solver",
          "enabled": true,
          "description": "FiPy steady-state diffusion solver",
          "parameters": {},
          "parameter_nodes": ["param_diffusion_max_iter", "param_diffusion_tolerance", "param_diffusion_solver_type"],
          "position": {"x": 200, "y": 50}
        }
      ],
      "subworkflow_calls": [],
      "parameters": [
        {"id": "param_diffusion_max_iter", "label": "Max Iterations", "parameters": {"max_iterations": 1000}, "position": {"x": 400, "y": 50}},
        {"id": "param_diffusion_tolerance", "label": "Tolerance", "parameters": {"tolerance": 1e-6}, "position": {"x": 500, "y": 50}},
        {"id": "param_diffusion_solver_type", "label": "Solver Type", "parameters": {"solver_type": "steady_state"}, "position": {"x": 600, "y": 50}}
      ],
      "execution_order": ["diffusion_solver"],
      "enabled": true
    },
    "finalization": {
      "description": "Finalization composer: orchestrates final plots and simulation summary",
      "deletable": true,
      "controller": {
        "id": "controller-finalization",
        "label": "FINALIZATION COMPOSER",
        "position": {"x": 50, "y": 50},
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [
        {
          "id": "call_generate_plots_final",
          "subworkflow_name": "Generate_plots",
          "iterations": 1,
          "enabled": true,
          "description": "Generate final state plots",
          "parameters": {},
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 100}
        },
        {
          "id": "call_summarize_simulation",
          "subworkflow_name": "Summarize_simulation",
          "iterations": 1,
          "enabled": true,
          "description": "Print summary and save simulation data",
          "parameters": {},
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 250}
        }
      ],
      "parameters": [],
      "execution_order": ["call_generate_plots_final", "call_summarize_simulation"],
      "enabled": true
    },
    "Setup_simulation": {
      "description": "Setup simulation infrastructure and spatial domain",
      "deletable": true,
      "controller": {
        "id": "controller-setup-simulation",
        "label": "SETUP SIMULATION CONTROLLER",
        "position": {"x": 50, "y": 50},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "setup_sim",
          "function_name": "setup_simulation",
          "enabled": true,
          "description": "Initialize simulation infrastructure",
          "parameters": {},
          "parameter_nodes": ["param_sim_name", "param_sim_total_steps", "param_sim_dt", "param_sim_output_dir"],
          "position": {"x": 200, "y": 50}
        },
        {
          "id": "setup_domain_node",
          "function_name": "setup_domain",
          "enabled": true,
          "description": "Define 2D spatial domain",
          "parameters": {},
          "parameter_nodes": ["param_domain_dimensions", "param_domain_size_x", "param_domain_size_y", "param_domain_nx", "param_domain_ny", "param_domain_cell_height"],
          "position": {"x": 200, "y": 150}
        }
      ],
      "subworkflow_calls": [],
      "parameters": [
        {"id": "param_sim_name", "label": "Simulation Name", "parameters": {"name": "Diffusion-Reaction Test"}, "position": {"x": 400, "y": 50}},
        {"id": "param_sim_total_steps", "label": "Total Steps", "parameters": {"total_steps": 1}, "position": {"x": 550, "y": 50}},
        {"id": "param_sim_dt", "label": "Time Step (dt)", "parameters": {"dt": 1.0}, "position": {"x": 700, "y": 50}},
        {"id": "param_sim_output_dir", "label": "Output Directory", "parameters": {"output_dir": "results"}, "position": {"x": 850, "y": 50}},
        {"id": "param_domain_dimensions", "label": "Dimensions", "parameters": {"dimensions": 2}, "position": {"x": 400, "y": 150}},
        {"id": "param_domain_size_x", "label": "Size X (μm)", "parameters": {"size_x": 500.0}, "position": {"x": 550, "y": 150}},
        {"id": "param_domain_size_y", "label": "Size Y (μm)", "parameters": {"size_y": 500.0}, "position": {"x": 700, "y": 150}},
        {"id": "param_domain_nx", "label": "Grid NX", "parameters": {"nx": 50}, "position": {"x": 850, "y": 150}},
        {"id": "param_domain_ny", "label": "Grid NY", "parameters": {"ny": 50}, "position": {"x": 1000, "y": 150}},
        {"id": "param_domain_cell_height", "label": "Cell Height (μm)", "parameters": {"cell_height": 20.0}, "position": {"x": 1150, "y": 150}}
      ],
      "execution_order": ["setup_sim", "setup_domain_node"],
      "enabled": true
    },
    "Setup_substances": {
      "description": "Setup all substances using batch configuration",
      "deletable": true,
      "controller": {
        "id": "controller-setup-substances",
        "label": "SETUP SUBSTANCES CONTROLLER",
