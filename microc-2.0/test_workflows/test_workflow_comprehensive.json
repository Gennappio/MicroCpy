{
  "version": "2.0",
  "name": "Comprehensive v2.0 Test Workflow",
  "description": "Tests all v2.0 features: subworkflow calls, step parameters, context mapping, results, nested directories",
  "metadata": {
    "author": "Test Suite",
    "created": "2026-01-13",
    "gui": {
      "subworkflow_kinds": {
        "main": "composer",
        "helper_a": "subworkflow",
        "helper_b": "subworkflow"
      }
    }
  },
  "subworkflows": {
    "main": {
      "description": "Main composer - orchestrates helper subworkflows",
      "deletable": false,
      "controller": {
        "id": "controller-main",
        "label": "MAIN CONTROLLER",
        "position": {"x": 100, "y": 100},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "node_1",
          "function_name": "debug_initialization_1",
          "enabled": true,
          "description": "Start main",
          "parameters": {
            "message": "[MAIN] Starting main composer"
          },
          "position": {"x": 200, "y": 100}
        },
        {
          "id": "node_4",
          "function_name": "debug_initialization_2",
          "enabled": true,
          "description": "Complete",
          "parameters": {
            "message": "[MAIN] All helpers completed successfully"
          },
          "position": {"x": 200, "y": 400}
        }
      ],
      "subworkflow_calls": [
        {
          "id": "node_2",
          "subworkflow_name": "helper_a",
          "iterations": 1,
          "enabled": true,
          "description": "Call helper A",
          "parameters": {
            "num_steps": 3
          },
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 200}
        },
        {
          "id": "node_3",
          "subworkflow_name": "helper_b",
          "iterations": 1,
          "enabled": true,
          "description": "Call helper B",
          "parameters": {
            "num_steps": 5
          },
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 300}
        }
      ],
      "parameters": [],
      "execution_order": ["node_1", "node_2", "node_3", "node_4"],
      "enabled": true
    },
    "helper_a": {
      "description": "Helper A - Simple logging subworkflow",
      "deletable": true,
      "controller": {
        "id": "controller-helper_a",
        "label": "HELPER A CONTROLLER",
        "position": {"x": 100, "y": 100},
        "number_of_steps": 3
      },
      "functions": [
        {
          "id": "node_a1",
          "function_name": "debug_intracellular_1",
          "enabled": true,
          "description": "Intracellular",
          "parameters": {
            "message": "[HELPER_A] Intracellular processing"
          },
          "position": {"x": 200, "y": 100}
        },
        {
          "id": "node_a2",
          "function_name": "debug_microenvironment_1",
          "enabled": true,
          "description": "Microenvironment",
          "parameters": {
            "message": "[HELPER_A] Microenvironment step"
          },
          "position": {"x": 200, "y": 200}
        }
      ],
      "subworkflow_calls": [],
      "parameters": [],
      "execution_order": ["node_a1", "node_a2"],
      "enabled": true
    },
    "helper_b": {
      "description": "Helper B - Calls helper_a and does additional processing",
      "deletable": true,
      "controller": {
        "id": "controller-helper_b",
        "label": "HELPER B CONTROLLER",
        "position": {"x": 100, "y": 100},
        "number_of_steps": 5
      },
      "functions": [
        {
          "id": "node_b1",
          "function_name": "debug_initialization_1",
          "enabled": true,
          "description": "Start B",
          "parameters": {
            "message": "[HELPER_B] Starting helper B"
          },
          "position": {"x": 200, "y": 100}
        },
        {
          "id": "node_b3",
          "function_name": "debug_intercellular_1",
          "enabled": true,
          "description": "Intercellular",
          "parameters": {
            "message": "[HELPER_B] Intercellular processing"
          },
          "position": {"x": 200, "y": 300}
        },
        {
          "id": "node_b4",
          "function_name": "debug_finalization_1",
          "enabled": true,
          "description": "Finalize B",
          "parameters": {
            "message": "[HELPER_B] Finalizing helper B"
          },
          "position": {"x": 200, "y": 400}
        }
      ],
      "subworkflow_calls": [
        {
          "id": "node_b2",
          "subworkflow_name": "helper_a",
          "iterations": 1,
          "enabled": true,
          "description": "Nested call to helper A",
          "parameters": {
            "num_steps": 2
          },
          "context_mapping": {},
          "parameter_nodes": [],
          "position": {"x": 200, "y": 200}
        }
      ],
      "parameters": [],
      "execution_order": ["node_b1", "node_b2", "node_b3", "node_b4"],
      "enabled": true
    }
  }
}
