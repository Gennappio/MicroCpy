{
  "version": "2.0",
  "name": "PhysiCell Hill Rule Demo",
  "description": "Black-box facade demo: oxygen decays, an 'increases necrosis' Hill rule fires on every phenotype tick, and occ_events.jsonl streams rule_engine_changed events to the GUI. Builds against unmodified PhysiBoSS-master/. See docs/Physicell_Facade_plan.md.",
  "kernel": "physicell",
  "kernel_config": {
    "physicell": {
      "domain": {
        "x_min": -150.0, "x_max": 150.0,
        "y_min": -150.0, "y_max": 150.0,
        "z_min": -10.0, "z_max": 10.0,
        "dx": 20.0, "dy": 20.0, "dz": 20.0,
        "use_2D": true
      },
      "overall": {
        "max_time": 5.0,
        "dt_diffusion": 0.01,
        "dt_mechanics": 0.1,
        "dt_phenotype": 0.1
      },
      "parallel": {"omp_num_threads": 2},
      "save": {
        "folder": "output",
        "full_data_interval": 1.0,
        "svg_interval": 1.0,
        "svg_enabled": false
      },
      "options": {"random_seed": 7, "virtual_wall_at_domain_edge": true},
      "user_parameters": {"number_of_cells": 3}
    }
  },
  "metadata": {
    "author": "OpenCellComms / PhysiCell facade",
    "experiment": "PhysiCell black-box facade smoke",
    "notes": "Run via CLI: python run_workflow.py --workflow opencellcomms_gui/server/workflows/physicell_hill_demo.json. Requires PHYSICELL_CPP=g++-14 (or any OpenMP-capable g++) and PHYSIBOSS_ROOT pointing at the upstream tree.",
    "gui": {
      "subworkflow_kinds": {"main": "composer"}
    }
  },
  "subworkflows": {
    "main": {
      "description": "Codegen-only: declares one substrate, one cell type, one Hill rule. Execution is handed off to physicell_backend.run() — these nodes are no-ops at sim time.",
      "enabled": true,
      "deletable": false,
      "execution_order": ["sub_o2", "ct_tumor", "rule_o2_necrosis"],
      "controller": {
        "id": "controller-main",
        "type": "controller",
        "label": "PHYSICELL FACADE",
        "position": {"x": 350.0, "y": -100.0},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "sub_o2",
          "function_name": "define_substrate",
          "parameters": {},
          "enabled": true,
          "position": {"x": 100.0, "y": 100.0},
          "description": "Oxygen substrate; high initial value + decay produces a falling signal over the run.",
          "custom_name": "",
          "step_count": 1,
          "parameter_nodes": ["pn_oxygen"]
        },
        {
          "id": "ct_tumor",
          "function_name": "define_cell_type",
          "parameters": {},
          "enabled": true,
          "position": {"x": 400.0, "y": 100.0},
          "description": "Single tumor cell type; default phenotype values.",
          "custom_name": "",
          "step_count": 1,
          "parameter_nodes": ["pn_tumor"]
        },
        {
          "id": "rule_o2_necrosis",
          "function_name": "define_hill_rule",
          "parameters": {},
          "enabled": true,
          "position": {"x": 700.0, "y": 100.0},
          "description": "As oxygen increases, necrosis rate moves from 0 toward max_response=0.5.",
          "custom_name": "",
          "step_count": 1,
          "parameter_nodes": ["pn_rule_o2_necrosis"]
        }
      ],
      "parameters": [
        {
          "id": "pn_oxygen",
          "type": "dictParameterNode",
          "label": "Oxygen (substrate)",
          "target_param": "substrate",
          "position": {"x": 100.0, "y": 280.0},
          "entries": [
            {"key": "name", "value": "oxygen", "valueType": "string"},
            {"key": "units", "value": "mmHg", "valueType": "string"},
            {"key": "diffusion_coefficient", "value": 100000.0, "valueType": "float"},
            {"key": "decay_rate", "value": 1.0, "valueType": "float"},
            {"key": "initial_condition", "value": 38.0, "valueType": "float"},
            {"key": "dirichlet_enabled", "value": false, "valueType": "bool"},
            {"key": "dirichlet_value", "value": 0.0, "valueType": "float"}
          ]
        },
        {
          "id": "pn_tumor",
          "type": "dictParameterNode",
          "label": "Tumor (cell type)",
          "target_param": "cell_type",
          "position": {"x": 400.0, "y": 280.0},
          "entries": [
            {"key": "name", "value": "tumor", "valueType": "string"},
            {"key": "id", "value": 0, "valueType": "int"}
          ]
        },
        {
          "id": "pn_rule_o2_necrosis",
          "type": "dictParameterNode",
          "label": "Hill: O2 → necrosis",
          "target_param": "rule",
          "position": {"x": 700.0, "y": 280.0},
          "entries": [
            {"key": "cell_type", "value": "tumor", "valueType": "string"},
            {"key": "signal", "value": "oxygen", "valueType": "string"},
            {"key": "direction", "value": "increases", "valueType": "string"},
            {"key": "behavior", "value": "necrosis", "valueType": "string"},
            {"key": "max_response", "value": 0.5, "valueType": "float"},
            {"key": "half_max", "value": 5.0, "valueType": "float"},
            {"key": "hill_power", "value": 8.0, "valueType": "float"},
            {"key": "use_on_dead", "value": 0, "valueType": "int"}
          ]
        }
      ]
    }
  }
}
