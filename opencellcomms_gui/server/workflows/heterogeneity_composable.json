{
  "version": "2.0",
  "name": "Heterogeneity composable",
  "description": "Demonstrates the CustomModules composer: uses the PhysiBoSS 'heterogeneity' sample project's custom C++ layer (oncoprotein-driven cell diversity) combined with OCC Hill rules and observability. The Configuration composer sets up oxygen + cancer cell type; the CustomModules composer points at heterogeneity/custom_modules/.",
  "kernel": "biophysics",
  "metadata": {
    "author": "OpenCellComms / PhysiCell facade",
    "experiment": "heterogeneity project template demo",
    "notes": "Run: PHYSICELL_CPP=g++-14 PHYSIBOSS_ROOT=/path/to/PhysiBoSS-master python run_workflow.py --workflow ../opencellcomms_gui/server/workflows/heterogeneity_composable.json",
    "gui": {
      "subworkflow_kinds": {
        "main": "composer",
        "Configuration": "composer",
        "CustomModules": "composer",
        "Engine": "composer",
        "Postprocessing": "composer"
      }
    }
  },
  "subworkflows": {
    "main": {
      "description": "Orchestrator: Configuration → CustomModules → Engine → Postprocessing.",
      "enabled": true,
      "deletable": false,
      "execution_order": ["call_config", "call_custom", "call_engine", "call_postprocess"],
      "controller": {
        "id": "controller-main",
        "type": "controller",
        "label": "MAIN ORCHESTRATOR",
        "position": {"x": 700.0, "y": -140.0},
        "number_of_steps": 1
      },
      "functions": [],
      "subworkflow_calls": [
        {
          "id": "call_config",
          "type": "subworkflow_call",
          "subworkflow_name": "Configuration",
          "iterations": 1,
          "enabled": true,
          "position": {"x": 100.0, "y": 100.0},
          "description": "Oxygen substrate + cancer cell type + oxygen→proliferation Hill rule.",
          "parameters": {},
          "parameter_nodes": [],
          "context_mapping": {}
        },
        {
          "id": "call_custom",
          "type": "subworkflow_call",
          "subworkflow_name": "CustomModules",
          "iterations": 1,
          "enabled": true,
          "position": {"x": 400.0, "y": 100.0},
          "description": "Use the heterogeneity project's custom C++ cell behavior.",
          "parameters": {},
          "parameter_nodes": [],
          "context_mapping": {}
        },
        {
          "id": "call_engine",
          "type": "subworkflow_call",
          "subworkflow_name": "Engine",
          "iterations": 1,
          "enabled": true,
          "position": {"x": 700.0, "y": 100.0},
          "description": "Run PhysiCell.",
          "parameters": {},
          "parameter_nodes": [],
          "context_mapping": {}
        },
        {
          "id": "call_postprocess",
          "type": "subworkflow_call",
          "subworkflow_name": "Postprocessing",
          "iterations": 1,
          "enabled": true,
          "position": {"x": 1000.0, "y": 100.0},
          "description": "Summarize events.",
          "parameters": {},
          "parameter_nodes": [],
          "context_mapping": {}
        }
      ],
      "parameters": []
    },
    "Configuration": {
      "description": "Oxygen substrate + cancer cell type (matches the heterogeneity project's expected XML). Adds a Hill rule: oxygen increases proliferation.",
      "enabled": true,
      "deletable": false,
      "execution_order": ["sub_oxygen", "ct_cancer", "rule_o2_prolif"],
      "controller": {
        "id": "controller-config",
        "type": "controller",
        "label": "CONFIGURATION",
        "position": {"x": 700.0, "y": -140.0},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "sub_oxygen",
          "function_name": "define_substrate",
          "parameters": {},
          "enabled": true,
          "position": {"x": 100.0, "y": 100.0},
          "description": "Oxygen substrate matching heterogeneity project defaults.",
          "step_count": 1,
          "parameter_nodes": ["pn_oxygen"]
        },
        {
          "id": "ct_cancer",
          "function_name": "define_cell_type",
          "parameters": {},
          "enabled": true,
          "position": {"x": 400.0, "y": 100.0},
          "description": "Cancer cell type (ID 0) as expected by the heterogeneity project XML.",
          "step_count": 1,
          "parameter_nodes": ["pn_cancer"]
        },
        {
          "id": "rule_o2_prolif",
          "function_name": "define_hill_rule",
          "parameters": {},
          "enabled": true,
          "position": {"x": 700.0, "y": 100.0},
          "description": "Oxygen increases cycle entry rate (Hill rule on top of heterogeneity C++ logic).",
          "step_count": 1,
          "parameter_nodes": ["pn_rule_o2_prolif"]
        }
      ],
      "subworkflow_calls": [],
      "parameters": [
        {
          "id": "pn_oxygen",
          "type": "dictParameterNode",
          "label": "Oxygen (substrate)",
          "target_param": "substrate",
          "position": {"x": 100.0, "y": 280.0},
          "entries": [
            {"key": "name", "value": "oxygen", "valueType": "string"},
            {"key": "units", "value": "dimensionless", "valueType": "string"},
            {"key": "diffusion_coefficient", "value": 100000.0, "valueType": "float"},
            {"key": "decay_rate", "value": 0.1, "valueType": "float"},
            {"key": "initial_condition", "value": 38.0, "valueType": "float"},
            {"key": "dirichlet_enabled", "value": true, "valueType": "bool"},
            {"key": "dirichlet_value", "value": 38.0, "valueType": "float"}
          ]
        },
        {
          "id": "pn_cancer",
          "type": "dictParameterNode",
          "label": "cancer cell (cell type)",
          "target_param": "cell_type",
          "position": {"x": 400.0, "y": 280.0},
          "entries": [
            {"key": "name", "value": "cancer cell", "valueType": "string"},
            {"key": "id", "value": 0, "valueType": "int"}
          ]
        },
        {
          "id": "pn_rule_o2_prolif",
          "type": "dictParameterNode",
          "label": "O2 → cycle entry",
          "target_param": "rule",
          "position": {"x": 700.0, "y": 280.0},
          "entries": [
            {"key": "cell_type", "value": "cancer cell", "valueType": "string"},
            {"key": "signal", "value": "oxygen", "valueType": "string"},
            {"key": "direction", "value": "increases", "valueType": "string"},
            {"key": "behavior", "value": "cycle entry", "valueType": "string"},
            {"key": "max_response", "value": 0.001, "valueType": "float"},
            {"key": "half_max", "value": 21.5, "valueType": "float"},
            {"key": "hill_power", "value": 4.0, "valueType": "float"},
            {"key": "use_on_dead", "value": 0, "valueType": "int"}
          ]
        }
      ]
    },
    "CustomModules": {
      "description": "Points at the heterogeneity project's custom_modules/. The project's phenotype_function assigns random oncoprotein values that determine each cell's proliferation rate.",
      "enabled": true,
      "deletable": false,
      "execution_order": ["tmpl_node"],
      "controller": {
        "id": "controller-custom",
        "type": "controller",
        "label": "CUSTOM MODULES",
        "position": {"x": 700.0, "y": -140.0},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "tmpl_node",
          "function_name": "select_project_template",
          "parameters": {"project_name": "heterogeneity"},
          "enabled": true,
          "position": {"x": 100.0, "y": 100.0},
          "description": "Use heterogeneity/custom_modules/: oncoprotein-driven cell heterogeneity with OCC observability wrapper injected automatically.",
          "step_count": 1,
          "parameter_nodes": []
        }
      ],
      "subworkflow_calls": [],
      "parameters": []
    },
    "Engine": {
      "description": "Generates project, compiles, and runs with the heterogeneity custom modules.",
      "enabled": true,
      "deletable": false,
      "execution_order": ["run_sim"],
      "controller": {
        "id": "controller-engine",
        "type": "controller",
        "label": "ENGINE",
        "position": {"x": 700.0, "y": -140.0},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "run_sim",
          "function_name": "run_physicell_simulation",
          "parameters": {},
          "enabled": true,
          "position": {"x": 100.0, "y": 100.0},
          "description": "Codegen → make → spawn → tail occ_events.jsonl.",
          "step_count": 1,
          "parameter_nodes": [
            "pn_domain", "pn_overall", "pn_save",
            "pn_options", "pn_parallel", "pn_user_parameters"
          ]
        }
      ],
      "subworkflow_calls": [],
      "parameters": [
        {
          "id": "pn_domain",
          "type": "dictParameterNode",
          "label": "Domain",
          "target_param": "domain",
          "position": {"x": 100.0, "y": 280.0},
          "entries": [
            {"key": "x_min", "value": -750.0, "valueType": "float"},
            {"key": "x_max", "value": 750.0, "valueType": "float"},
            {"key": "y_min", "value": -750.0, "valueType": "float"},
            {"key": "y_max", "value": 750.0, "valueType": "float"},
            {"key": "z_min", "value": -10.0, "valueType": "float"},
            {"key": "z_max", "value": 10.0, "valueType": "float"},
            {"key": "dx", "value": 30.0, "valueType": "float"},
            {"key": "dy", "value": 30.0, "valueType": "float"},
            {"key": "dz", "value": 30.0, "valueType": "float"},
            {"key": "use_2D", "value": true, "valueType": "bool"}
          ]
        },
        {
          "id": "pn_overall",
          "type": "dictParameterNode",
          "label": "Timing",
          "target_param": "overall",
          "position": {"x": 100.0, "y": 460.0},
          "entries": [
            {"key": "max_time", "value": 120.0, "valueType": "float"},
            {"key": "dt_diffusion", "value": 0.01, "valueType": "float"},
            {"key": "dt_mechanics", "value": 0.1, "valueType": "float"},
            {"key": "dt_phenotype", "value": 6.0, "valueType": "float"}
          ]
        },
        {
          "id": "pn_save",
          "type": "dictParameterNode",
          "label": "Save",
          "target_param": "save",
          "position": {"x": 100.0, "y": 640.0},
          "entries": [
            {"key": "folder", "value": "output", "valueType": "string"},
            {"key": "full_data_interval", "value": 30.0, "valueType": "float"},
            {"key": "svg_interval", "value": 30.0, "valueType": "float"},
            {"key": "svg_enabled", "value": false, "valueType": "bool"}
          ]
        },
        {
          "id": "pn_options",
          "type": "dictParameterNode",
          "label": "Options",
          "target_param": "options",
          "position": {"x": 100.0, "y": 820.0},
          "entries": [
            {"key": "random_seed", "value": 0, "valueType": "int"},
            {"key": "virtual_wall_at_domain_edge", "value": true, "valueType": "bool"}
          ]
        },
        {
          "id": "pn_parallel",
          "type": "dictParameterNode",
          "label": "Parallel",
          "target_param": "parallel",
          "position": {"x": 100.0, "y": 1000.0},
          "entries": [
            {"key": "omp_num_threads", "value": 4, "valueType": "int"}
          ]
        },
        {
          "id": "pn_user_parameters",
          "type": "dictParameterNode",
          "label": "User parameters",
          "target_param": "user_parameters",
          "position": {"x": 100.0, "y": 1180.0},
          "entries": [
            {"key": "number_of_cells", "value": 200, "valueType": "int"},
            {"key": "oncoprotein_mean", "value": 1.0, "valueType": "float"},
            {"key": "oncoprotein_sd", "value": 0.25, "valueType": "float"},
            {"key": "oncoprotein_min", "value": 0.0, "valueType": "float"},
            {"key": "oncoprotein_max", "value": 2.0, "valueType": "float"}
          ]
        }
      ]
    },
    "Postprocessing": {
      "description": "Summarize OCC events. Add cell-population analysis or image export nodes here.",
      "enabled": true,
      "deletable": false,
      "execution_order": ["summarize"],
      "controller": {
        "id": "controller-post",
        "type": "controller",
        "label": "POSTPROCESSING",
        "position": {"x": 700.0, "y": -140.0},
        "number_of_steps": 1
      },
      "functions": [
        {
          "id": "summarize",
          "function_name": "summarize_physicell_events",
          "parameters": {"max_lines_to_show": 5},
          "enabled": true,
          "position": {"x": 100.0, "y": 100.0},
          "description": "Tally rule_engine_changed events.",
          "step_count": 1,
          "parameter_nodes": []
        }
      ],
      "subworkflow_calls": [],
      "parameters": []
    }
  }
}
